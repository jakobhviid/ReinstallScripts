# Ghostty config — Linux counterpart of Mac/assets/ghostty.config.
# Keep cross-platform settings (colors, palette, padding, cursor, behavior,
# link, font-feature) in sync with Mac/assets/ghostty.config. Mac-only keys
# (macos-*, cmd+ keybinds) edit only Mac/. Linux-only keys (font-family,
# portal-specific comments) edit only here.

# ── Font ─────────────────────────────────────────────────────────────
# Ghostty on Linux defaults to "monospace" (fontconfig). FiraCode Nerd Font
# is installed on every machine in the fleet via `just zsh` (brew cask
# font-fira-code-nerd-font) and as a fallback via the bazzite-custom image's
# nerd-fonts RPM, so it's safe to require here. FiraCode is picked over
# JetBrains Mono (Mac's bundled default) because FiraCode is already in the
# Linux Brewfiles and ships the strongest programming-ligature set of the
# four Nerd Fonts we install: ===, !==, -->, ==>, ->, =>, <=, >=, &&, ||
# all render via calt (on by default).
font-family = "FiraCode Nerd Font"

# `dlig` is a no-op for FiraCode (its ligatures live in calt), but kept on
# in case the user swaps to JetBrains Mono — its arrow ligatures live in
# dlig, which Ghostty 1.2.0 turned off by default.
font-feature = dlig

# ── Background transparency + blur ───────────────────────────────────
# background-blur requires a compositor that exposes a blur API
# (KDE/KWin, Hyprland). GNOME/Mutter does NOT — the key is a silent no-op
# on Bazzite until that changes. Opacity still applies. The pre-1.x key
# name was `background-blur-radius`; current canonical is `background-blur`.
background-opacity = 0.84
background-blur = 24

# Initial window size in terminal cells (columns × rows). Only affects newly
# created windows, not existing ones, splits, or tabs. GTK note: window
# decorations aren't counted, so the grid may end up a row or two shorter
# than requested when CSD is on — `window-decoration = none` makes it exact.
window-width = 124
window-height = 36

# ── Cursor ───────────────────────────────────────────────────────────
cursor-style = bar
cursor-style-blink = true
cursor-color = ffffff
cursor-text = 000000

# ── Core colors ──────────────────────────────────────────────────────
background = 15191f
foreground = dcdcdc
selection-background = b3d7ff
selection-foreground = 000000

# Use Ghostty's own background/foreground for the GTK chrome (headerbar,
# tab strip) instead of the system Adwaita theme. Makes the window read
# as one continuous dark surface; still respects window-decoration.
window-theme = ghostty
# Override the titlebar foreground to pure white. Without this, the headerbar
# icons (tab close X, new-tab +, window controls) inherit `foreground = dcdcdc`
# above and read as muted grey against the dark bar. Only takes effect when
# window-theme = ghostty.
window-titlebar-foreground = ffffff

# ── 16-color ANSI palette ────────────────────────────────────────────
palette = 0=#14191e
palette = 1=#eb5032
palette = 2=#3bea06
palette = 3=#c7c400
palette = 4=#3f5bff
palette = 5=#e44dee
palette = 6=#00c5c7
palette = 7=#c7c7c7
palette = 8=#686868
palette = 9=#dd7975
palette = 10=#58e790
palette = 11=#ece100
palette = 12=#a7abf2
palette = 13=#e786f0
palette = 14=#60fdff
palette = 15=#ffffff

# ── Window chrome ────────────────────────────────────────────────────
window-padding-x = 10
# window-padding-y format: "TOP,BOTTOM" — top tightened to 4 to sit closer
# under the titlebar; bottom kept at 8.
window-padding-y = 4,8
window-padding-balance = true
# Ghostty Linux uses GTK CSD with a native titlebar + a tab bar below it
# (gtk-titlebar-style defaults to `native`). The `tabs` style that merges
# tabs into the titlebar was tried and reverted: the resulting bar had no
# draggable area in practice. No equivalent of Mac's macos-titlebar-style
# / proxy-icon needed.

# ── Quick Terminal (quake-style dropdown) ────────────────────────────
# Linux global keybinds use the xdg-desktop-portal GlobalShortcuts portal.
# GNOME (Bazzite) supports this; you may see a one-time permission prompt
# the first time you press the shortcut.
#
# ctrl+alt+t is GNOME's default "open terminal" binding. Ghostty's portal
# grab should win, but if it conflicts, unbind GNOME's via:
#   gsettings set org.gnome.settings-daemon.plugins.media-keys terminal "['']"
keybind = global:ctrl+escape=toggle_quick_terminal
keybind = global:ctrl+alt+t=new_window
quick-terminal-position = left
# Width: 1000 px. At JetBrains Mono 13pt that's ~128 columns. Tune to taste:
#   720px ≈ strict half of a 1440-wide laptop
#   1000px ≈ ~58% of 14" laptop (still well under 1/3 of a 3440 ultrawide)
#   1150px ≈ 1/3 of a 3440 ultrawide
quick-terminal-size = 1000px
quick-terminal-animation-duration = 0.2
quick-terminal-screen = mouse
quick-terminal-autohide = true

# ── Misc niceties ────────────────────────────────────────────────────
copy-on-select = clipboard
mouse-hide-while-typing = true
confirm-close-surface = false

# Auto-allow programs to READ the system clipboard via OSC 52 escape
# sequences (used by neovim/tmux yank-over-SSH, etc.). Default is `ask`,
# which interrupts the flow with a dialog every time. Write is already
# `allow` by default. Mild loosening — any program with stdout can stuff
# requests at your clipboard. Personal-machine appropriate.
clipboard-read = allow

# Click-link to follow: enabled. ctrl+click on URLs (https://, file://, etc.)
# in the terminal opens them in the default app. NOTE: plain folder paths
# like /home/jakob/foo are NOT matched by default — they need a custom
# `link = ...` regex. file:// URIs do work out of the box.
link-url = true
link-previews = true

# ── SSH integration ──────────────────────────────────────────────────
# Ghostty sets TERM=xterm-ghostty, which most remote hosts don't have a
# terminfo entry for — leading to `tput: unknown terminal` errors, broken
# arrow keys, garbled vim/htop, etc. These two flags wrap the `ssh` command
# so Ghostty copies its terminfo to the remote on first connect (ssh-terminfo)
# and forwards a few env vars like COLORTERM (ssh-env). Setting is additive —
# does not disable cursor/title/path defaults.
shell-integration-features = ssh-env,ssh-terminfo
