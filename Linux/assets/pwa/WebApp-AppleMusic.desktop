[Desktop Entry]
Version=1.0
Type=Application
Terminal=false
StartupNotify=true
Categories=GTK;AudioVideo;Audio;Music;Player;
Name=Apple Music
Exec=brave-browser --user-data-dir=__HOME__/.config/BraveSoftware/WebApps/WebApp-AppleMusic --ozone-platform=x11 --force-dark-mode --app=https://music.apple.com --class=WebApp-AppleMusic --name=WebApp-AppleMusic
StartupWMClass=WebApp-AppleMusic
Icon=apple-music
