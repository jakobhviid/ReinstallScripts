[Desktop Entry]
Version=1.0
Type=Application
Terminal=false
StartupNotify=true
Categories=GTK;Office;Calendar;
Name=Proton Calendar
Exec=brave-browser --user-data-dir=__HOME__/.config/BraveSoftware/WebApps/WebApp-ProtonCalendar --ozone-platform=x11 --force-dark-mode --app=https://calendar.proton.me --class=WebApp-ProtonCalendar --name=WebApp-ProtonCalendar
StartupWMClass=WebApp-ProtonCalendar
Icon=proton-calendar
