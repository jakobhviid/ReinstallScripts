[Desktop Entry]
Version=1.0
Type=Application
Terminal=false
StartupNotify=true
Categories=GTK;Network;Email;
Name=Proton Mail
Exec=brave-browser --user-data-dir=__HOME__/.config/BraveSoftware/WebApps/WebApp-ProtonMail --ozone-platform=x11 --force-dark-mode --app=https://mail.proton.me --class=WebApp-ProtonMail --name=WebApp-ProtonMail
StartupWMClass=WebApp-ProtonMail
Icon=proton-mail
