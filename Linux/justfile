# Linux setup recipes — run from the Linux/ directory

# List available machines (Brewfile.* without the prefix)
_machines := `ls brewfiles/Brewfile.* 2>/dev/null | xargs -n1 basename | sed 's/Brewfile\.//' | tr '\n' ' '`

# Show available commands
default:
    @echo "Linux setup — run from the Linux/ directory"
    @echo ""
    @echo "Commands:"
    @echo "  just install [machine]   Run install-bazzite.sh with the given machine's Brewfile"
    @echo "  just update              Update brew/flatpak/zsh + re-apply all per-user fixes (no new installs, no machine arg)"
    @echo "  just backup [machine]    Dump current Homebrew + Flatpak state to Brewfile.<machine>"
    @echo "  just drift [machine]     Show what's out of sync with the repo (read-only)"
    @echo "  just reconcile [machine] Interactively add extras / drop missing from a machine's Brewfile"
    @echo "  just prune [machine]     Uninstall packages not in a machine's Brewfile (asks first)"
    @echo "  just install-missing [machine]   Install Brewfile entries that are missing on this machine"
    @echo "  just zsh                 Install/update Zsh plugins, config, and prompt theme"
    @echo "  just eq-import           Pull finalized EQ profiles from the pipewire-speaker-calibration repo into assets/speaker-eq/"
    @echo "  just speaker-eq [profile]  Install a PipeWire speaker EQ (auto-detects the connected speaker; 'all' installs every profile)"
    @echo "  just ghostty             Deploy assets/ghostty.config to ~/.config/ghostty/config"
    @echo "  just opencode            Deploy shared/opencode.jsonc to ~/.config/opencode/opencode.jsonc"
    @echo "  just ssh-config          Deploy managed SSH hosts to ~/.ssh/config.d/shared.conf (on-LAN direct, off-LAN via jump)"
    @echo "  just gnome-backup        Snapshot current GNOME shell settings"
    @echo "  just gnome-restore       Apply the snapshot to live GNOME shell (asks first)"
    @echo "  just ptyxis-backup       Snapshot current Ptyxis settings"
    @echo "  just ptyxis-restore      Apply the snapshot to live Ptyxis (asks first)"
    @echo ""
    @echo "Available machines: {{_machines}}"

# Run the full Bazzite installer for a machine. Re-runnable, idempotent.
install machine="":
    #!/usr/bin/env bash
    set -uo pipefail
    source "{{justfile_directory()}}/lib/common.sh"
    machine=$(resolve_machine "Pick a machine (number or name): " "{{machine}}") || { warn "No machine selected, exiting."; exit 0; }
    require_brewfile "$machine"
    "{{justfile_directory()}}/install-bazzite.sh" "$machine"

# Update everything already installed (brew, flatpak, GNOME extensions, zsh toolchain incl. re-templating ~/.zshrc.image) and re-apply every per-user fix (desktop icon/Exec overrides, 1Password, PWAs, autostart, ghostty, opencode, managed SSH config). Machine-agnostic — takes no argument, and server-safe: on a headless/CoreOS image (no gnome-shell) the flatpak, GNOME-extension and .desktop-override steps are skipped, so brew/zsh/opencode still update. Does NOT install new Brewfile entries (use 'just install' / 'just install-missing'), does NOT reload the GNOME/Ptyxis dconf snapshots (those would overwrite live tweaks — use 'just gnome-restore' / 'just ptyxis-restore'), and does NOT touch the OS image (use 'ujust update').
update:
    #!/usr/bin/env bash
    set -uo pipefail
    here="{{justfile_directory()}}"
    source "$here/lib/common.sh"
    source "$here/lib/install.sh"
    source "$here/lib/config.sh"
    if ! command -v brew &>/dev/null; then
        err "Homebrew not on PATH — run 'just install' first."
        exit 1
    fi
    # The run_config_* helpers resolve assets via $SCRIPT_DIR. Nothing update
    # touches is per-machine: the only machine-specific state is the GNOME/Ptyxis
    # dconf snapshots, which are restore operations left to gnome-restore/
    # ptyxis-restore (re-loading them here would clobber live-tuned settings).
    # So no MACHINE / Brewfile / machine arg is needed.
    export SCRIPT_DIR="$here"

    # ── Homebrew: refresh metadata, then upgrade installed formulae/casks.
    # Reset the desktop-customized casks BEFORE upgrade so brew's modified-
    # artifact guard doesn't abort their upgrade (see lib/install.sh). Only
    # fires when an upgrade is actually pending. `brew upgrade` never installs
    # anything not already present, so this stays update-only.
    info "Updating Homebrew metadata"
    brew update
    # Trust third-party taps BEFORE any reinstall/upgrade — reset_desktop_customized_casks
    # reinstalls ublue-os/tap casks, and brew upgrade pulls from the taps too.
    trust_brew_taps "$SCRIPT_DIR/../shared/brew-trusted-taps"
    reset_desktop_customized_casks
    info "Upgrading installed Homebrew packages"
    brew upgrade
    brew cleanup

    # Desktop vs headless: gate the GUI-only steps so this recipe runs cleanly
    # on both a graphical desktop and a headless/server image (CoreOS/bootc,
    # e.g. eternium) where flatpak, GNOME extensions and .desktop overrides make
    # no sense. is_desktop keys off gnome-shell (see lib/common.sh).
    if is_desktop; then
        # ── Flatpak: update installed apps + runtimes (no new installs).
        if command -v flatpak &>/dev/null; then
            info "Updating Flatpaks"
            flatpak update -y
        fi
        # ── GNOME Shell extensions (gext-managed, in ~/.local/share/gnome-shell).
        # Nothing else updates these: brew/flatpak don't own them, and `ujust
        # update` (topgrade) excludes the gnome-extensions step — so without this
        # they'd only ever move on a full reinstall. gext lives in ~/.local/bin,
        # not always on PATH in a non-interactive recipe.
        export PATH="$HOME/.local/bin:$PATH"
        if command -v gext &>/dev/null; then
            info "Updating GNOME Shell extensions (gext)"
            gext update || warn "gext update reported issues — continuing"
        fi
    else
        info "Headless/server (no gnome-shell) — skipping flatpak + GNOME extensions"
    fi

    # ── Zsh toolchain + config (plugins, prompt, tmux plugins, git identity).
    # Re-runs the zsh recipe; its brew installs are idempotent no-ops for
    # already-present tools and pull updates via the brew upgrade above.
    info "Updating Zsh setup"
    "{{just_executable()}}" zsh

    # ── Re-apply the machine-agnostic per-user fixes (same helpers as
    # install-bazzite.sh Phase 2, minus the two dconf restores). This is the
    # "ensure everything still has proper desktop files etc." part: brew/flatpak
    # upgrades and apps' own self-updaters restore pristine .desktop launchers,
    # so we re-apply icon/Exec overrides, 1Password integration, autostart flags.
    info "Re-applying per-user configuration"
    # Universal (also meaningful on a server): 1Password is self-guarded on the
    # binary; ghostty/opencode configs are just dotfiles (opencode is used on
    # eternium). The .desktop/icon/autostart/PWA overrides and the ghostty GNOME
    # keybinding are GUI-only, so they run on desktops only — on a server their
    # sources (system .desktop files, flatpak exports) don't exist and gsettings
    # has no session.
    if command -v 1password >/dev/null 2>&1; then
        run_config_1password
    fi
    if is_desktop; then
        run_config_desktop_overrides
        run_config_pwa
        run_config_autostart
        run_config_localsend
        run_config_ghostty_keybinding
    fi
    run_config_ghostty
    run_config_opencode
    run_config_ssh

    echo
    ok "Update complete."
    info "Not covered (by design): OS image + layered rpms + firmware ('ujust update' = topgrade, which also re-does brew/flatpak); GNOME/Ptyxis dconf snapshots ('just gnome-restore' / 'just ptyxis-restore'); new packages ('just install-missing <machine>')."

# Dump current Homebrew + Flatpak state to brewfiles/Brewfile.<machine>. Hand-edit before commit — the dump pulls in default Bazzite flatpaks.
backup machine="":
    #!/usr/bin/env bash
    set -uo pipefail
    source "{{justfile_directory()}}/lib/common.sh"
    machine=$(resolve_machine "Pick a machine (number, name, or new name): " "{{machine}}" create) || { warn "No machine selected, exiting."; exit 0; }
    mkdir -p brewfiles
    if [[ -L "brewfiles/Brewfile.$machine" ]]; then
        target=$(readlink "brewfiles/Brewfile.$machine")
        warn "brewfiles/Brewfile.$machine is a symlink → $target"
        warn "Dumping follows the link and will overwrite the target file's contents."
        printf 'Continue? [y/N] '
        read -r ans
        if ! [[ "$ans" =~ ^[Yy] ]]; then
            warn "Aborted. Nothing modified."
            exit 0
        fi
    fi
    if [[ -f "brewfiles/Brewfile.$machine" ]]; then
        info "Overwriting brewfiles/Brewfile.$machine"
    else
        info "Creating new brewfiles/Brewfile.$machine"
    fi
    brew bundle dump --file="brewfiles/Brewfile.$machine" --force --no-vscode
    ok "Saved to brewfiles/Brewfile.$machine"
    warn "Hand-edit before commit — the dump pulls in default GNOME flatpaks and runtime extensions."

# Show what's out of sync with the repo. Read-only — points at recipes to converge.
drift machine="":
    #!/usr/bin/env bash
    set -uo pipefail
    source "{{justfile_directory()}}/lib/common.sh"
    machine=$(resolve_machine "Pick a machine (number or name): " "{{machine}}") || { warn "No machine selected, exiting."; exit 0; }
    require_brewfile "$machine"

    declare -a fixes=()
    brew_prefix="$(brew --prefix)"
    here="{{justfile_directory()}}"

    # Role gate (same gnome-shell signal as install/update): a headless server
    # (any distro — FCOS eternium/nous, or Ubuntu/Debian) has none of the
    # desktop surface, so its image/brave/ghostty/gnome/PWA/rpm-layer checks are
    # skipped to avoid a wall of false failures. Universal checks (zsh, shell,
    # git, brewfile, opencode) still run.
    desktop=1
    is_desktop || desktop=0

    # ── image rebase ───────────────────────────────────────────────────
    # Confirm the machine is on a bazzite-custom variant. The rest of
    # this drift script assumes image-baked behavior (CLI tools live at
    # /usr/bin instead of brew, system-shipped unlock services, brave
    # policy in image, etc.), so this check sits first.
    # For container-image deployments the relevant field is
    # `.container-image-reference`, not `.origin` (which is null in this
    # case). Use `select(.booted)` instead of `[0]` so a staged pending
    # doesn't shadow the actually-running deployment.
    section "image / os"
    current_origin=$(rpm-ostree status --json 2>/dev/null \
        | jq -r '.deployments[] | select(.booted) | (.["container-image-reference"] // .origin // "")' 2>/dev/null)
    if (( ! desktop )); then
        # Servers self-manage their OS (FCOS via zincati/rpm-ostree, or an
        # apt-based distro); this repo doesn't track or rebase it, so just
        # report what's booted (empty on non-rpm-ostree distros).
        ok_line "server / headless — OS not managed by this repo${current_origin:+ (${current_origin##*/})}"
    else
        case "$current_origin" in
            *ghcr.io/jakobhviid/bazzite-custom:latest*)
                ok_line "bazzite-custom:latest"
                ;;
            *ghcr.io/jakobhviid/bazzite-nvidia-custom:latest*)
                ok_line "bazzite-nvidia-custom:latest"
                ;;
            *)
                short_current="${current_origin##*:}"
                fail_line "currently on ${current_origin:-<no deployment>}, expected ghcr.io/jakobhviid/bazzite-{,nvidia-}custom:latest"
                fixes+=("rebase to the bazzite-custom image|./install-bazzite.sh $machine")
                ;;
        esac
    fi

    # ── zsh templates ──────────────────────────────────────────────────
    section "zsh"
    rendered=$(mktemp)
    sed "s|BREW_PREFIX|$brew_prefix|g" "$here/assets/zshrc.template" > "$rendered"
    zd=0
    # Sanity-check that the user-owned ~/.zshrc still sources the managed
    # file. Without this, a user could remove the source line (intentionally
    # or via misedit) and drift would still pass — but the managed config
    # would silently not load. We only check for the source line, not the
    # whole bootstrap content (~/.zshrc is user-owned and may have arbitrary
    # additions around it).
    if [[ ! -f "$HOME/.zshrc" ]]; then
        fail_line "~/.zshrc (missing — run just zsh to bootstrap)"; zd=1
    elif ! grep -qF 'source ~/.zshrc.image' "$HOME/.zshrc"; then
        fail_line "~/.zshrc (missing 'source ~/.zshrc.image' line — managed config won't load)"; zd=1
    else
        ok_line "~/.zshrc (sources ~/.zshrc.image)"
    fi
    # Drift checks ~/.zshrc.image (the managed file), NOT ~/.zshrc body —
    # the latter is user-owned and may diverge freely (see `just zsh` recipe).
    for pair in \
        "$rendered:$HOME/.zshrc.image" \
        "$here/../shared/starship.toml:$HOME/.config/starship.toml" \
        "$here/../shared/tmux.conf:$HOME/.tmux.conf"
    do
        src="${pair%%:*}"; dst="${pair#*:}"; label="${dst/#$HOME/~}"
        d=$(file_drift "$src" "$dst")
        if [[ -z "$d" ]]; then ok_line "$label"; else fail_line "$label ($d)"; zd=1; fi
    done
    rm -f "$rendered"
    # ~/.zshrc.local was the per-machine override under the old single-file
    # model. Decommissioned 2026-05 — flag if it still exists so user migrates.
    if [[ -f "$HOME/.zshrc.local" ]]; then
        fail_line "~/.zshrc.local (decommissioned — no longer sourced; migrate into ~/.zshrc)"; zd=1
        fixes+=("migrate ~/.zshrc.local into ~/.zshrc, then rm ~/.zshrc.local|manual")
    fi
    (( zd )) && fixes+=("re-template ~/.zshrc.image, starship.toml, tmux.conf|just zsh")

    # ── default shell ──────────────────────────────────────────────────
    # Read the CONFIGURED login shell from /etc/passwd via getent, not the
    # current session's $SHELL. After 'usermod --shell ...' updates passwd,
    # $SHELL stays stale until the user logs out and back in, which would
    # make drift report incorrect "still bash" verdicts.
    section "default shell"
    configured_shell=$(getent passwd "$USER" 2>/dev/null | cut -d: -f7)
    [[ -z "$configured_shell" ]] && configured_shell="$SHELL"
    if [[ "$(basename "$configured_shell")" == "zsh" ]]; then
        if [[ "$SHELL" != "$configured_shell" ]]; then
            ok_line "$configured_shell (current session is $SHELL; log out and back in to switch)"
        else
            ok_line "$configured_shell"
        fi
    else
        fail_line "$configured_shell (expected zsh)"
        # Bazzite (and other atomic Fedora variants) doesn't ship util-linux-user,
        # so 'chsh' isn't available. The Bazzite docs recommend usermod with the
        # explicit /usr/bin/zsh path (not $(which zsh)) so the system-shipped
        # shell is used instead of a Homebrew install that may not persist
        # across rpm-ostree resets.
        # Refs: https://universal-blue.discourse.group/t/how-to-change-the-default-shell/3901
        shell_cmd=$'chsh -s $(which zsh)\n    (atomic desktops like Bazzite: sudo usermod --shell /usr/bin/zsh $USER)'
        fixes+=("switch login shell to zsh|$shell_cmd")
    fi

    # ── git identity ───────────────────────────────────────────────────
    section "git identity"
    declare -A git_expected=(
        [user.name]="Jakob Hviid, PhD"
        [user.email]="jakob@hviid.phd"
        [pull.rebase]="true"
    )
    gd=0
    for k in user.name user.email pull.rebase; do
        actual=$(git config --global "$k" 2>/dev/null || true)
        if [[ "$actual" == "${git_expected[$k]}" ]]; then
            ok_line "$k"
        else
            fail_line "$k = ${actual:-<unset>} (expected ${git_expected[$k]})"
            gd=1
        fi
    done
    (( gd )) && fixes+=("set git config (user.name, user.email, pull.rebase)|just zsh")

    # ── desktop-only checks (brave + ghostty) ─────────────────────────
    # Wrapped as one gnome-shell-gated block; bodies keep their original
    # indent to keep the diff reviewable.
    if (( desktop )); then

    # ── brave-origin policy ────────────────────────────────────────────
    # Linux is on Brave Origin (privacy-stripped variant), so the
    # canonical policy file for this platform is brave-origin-policy.json.
    # ~14 toggles from the historical full-Brave policy (Wallet, Rewards,
    # Leo, News, Tor, VPN, Talk, Playlist, Speedreader, Wayback, P3A, Web
    # Discovery, Stats Ping, IPFS) are no-ops on Origin because the
    # corresponding features are compiled out of the binary, so they're
    # omitted here; PromotionalTabs + the 4 PrivacySandbox keys are also
    # omitted (Brave defaults align). The Mac (mobileconfig) and Windows
    # (.json) policies keep the full set because they target regular Brave.
    section "brave (policy file)"
    managed="/etc/brave/policies/managed/brave-policy.json"
    bd=0
    if [[ ! -f "$managed" ]]; then
        fail_line "policy file not deployed (no $managed)"
        bd=1
    else
        expected=$(jq -S . "$here/assets/brave-origin-policy.json")
        actual=$(jq -S . "$managed" 2>/dev/null || echo '{}')
        # Surface BOTH missing-in-actual keys (need to land) AND
        # extra-in-actual keys (stale full-Brave policies left over from
        # before the Origin migration that should be dropped).
        mismatches=$(jq -r --argjson actual "$actual" '
            to_entries[] |
            select((.value | tojson) != ($actual[.key] | tojson)) |
            "\(.key)\t\(.value | tojson)\t\(($actual[.key] // null) | tojson)"
        ' <<< "$expected")
        extras=$(jq -r --argjson expected "$expected" '
            to_entries[] | select($expected[.key] == null) | .key
        ' <<< "$actual")
        if [[ -z "$mismatches" && -z "$extras" ]]; then
            ok_line "all keys match brave-origin-policy.json"
        else
            while IFS=$'\t' read -r key exp act; do
                [[ -z "$key" ]] && continue
                fail_line "$key (expected $exp, actual $act)"
            done <<< "$mismatches"
            while IFS= read -r key; do
                [[ -z "$key" ]] && continue
                fail_line "$key (extra — drop from deployed policy)"
            done <<< "$extras"
            bd=1
        fi
    fi
    # The deployed brave-policy.json is baked into the bazzite-custom
    # image. The local fix is to pull the latest image and reboot — by
    # the time a user sees drift here, the image has almost always been
    # rebuilt with the corrected policy already (daily rebuild). If
    # drift persists after the upgrade, the policy in this repo and the
    # one in the image are out of sync — that's a build-side fix, not
    # a machine-side fix.
    (( bd )) && fixes+=("update the system (pulls the latest image, then reboot)|ujust update")

    # ── ghostty ────────────────────────────────────────────────────────
    # Flat-file deploy: no template substitution, just a byte-for-byte
    # diff against ~/.config/ghostty/config.
    section "ghostty"
    gh_src="$here/assets/ghostty.config"
    gh_dst="$HOME/.config/ghostty/config"
    d=$(file_drift "$gh_src" "$gh_dst")
    if [[ -z "$d" ]]; then
        ok_line "~/.config/ghostty/config"
    elif [[ "$d" == missing ]]; then
        fail_line "~/.config/ghostty/config (missing)"
        fixes+=("deploy Ghostty config|just ghostty")
    else
        fail_line "~/.config/ghostty/config ($d)"
        fixes+=("re-deploy Ghostty config|just ghostty")
    fi
    # Ctrl+Alt+T must be the GNOME custom keybinding (run_config_ghostty_keybinding),
    # not Ghostty's own `keybind = global:` — the portal grab dies with the
    # process and the shortcut stops working as soon as the last window closes.
    # Check that the binding exists, points at <Ctrl><Alt>t, and resolves to
    # an executable. Skip silently if ghostty isn't installed yet (Phase 1
    # machines won't have it).
    if command -v ghostty >/dev/null 2>&1; then
        gh_kb_path="/org/gnome/settings-daemon/plugins/media-keys/custom-keybindings/ghostty/"
        gh_kb_cmd=$(gsettings get "org.gnome.settings-daemon.plugins.media-keys.custom-keybinding:$gh_kb_path" command 2>/dev/null | tr -d "'")
        gh_kb_bind=$(gsettings get "org.gnome.settings-daemon.plugins.media-keys.custom-keybinding:$gh_kb_path" binding 2>/dev/null | tr -d "'")
        gh_kb_exe="${gh_kb_cmd%% *}"
        if [[ -z "$gh_kb_cmd" ]]; then
            fail_line "Ctrl+Alt+T keybinding not configured"
            fixes+=("re-run Ghostty per-user config (binds Ctrl+Alt+T via GNOME so it survives Ghostty exit)|./install-bazzite.sh $machine")
        elif [[ ! -x "$gh_kb_exe" ]]; then
            fail_line "Ctrl+Alt+T command resolves to '$gh_kb_exe' which is not executable"
            fixes+=("re-run Ghostty per-user config (binds Ctrl+Alt+T via GNOME so it survives Ghostty exit)|./install-bazzite.sh $machine")
        elif [[ "$gh_kb_bind" != "<Ctrl><Alt>t" ]]; then
            fail_line "Ctrl+Alt+T keybinding is bound to '$gh_kb_bind' instead"
            fixes+=("re-run Ghostty per-user config (binds Ctrl+Alt+T via GNOME so it survives Ghostty exit)|./install-bazzite.sh $machine")
        else
            ok_line "Ctrl+Alt+T keybinding ($gh_kb_exe)"
        fi
    fi

    fi  # end desktop-only (brave + ghostty)

    # ── opencode ───────────────────────────────────────────────────────
    # Flat-file deploy of three shared files: main config, tui.json (theme
    # selection), and the hviid.cloud custom theme. Byte-for-byte diff each.
    section "opencode"
    for pair in \
        "opencode.jsonc:$HOME/.config/opencode/opencode.jsonc" \
        "opencode-tui.json:$HOME/.config/opencode/tui.json" \
        "opencode-theme.json:$HOME/.config/opencode/themes/hviid.cloud.json"; do
        oc_src="$here/../shared/${pair%%:*}"
        oc_dst="${pair#*:}"
        oc_label="~/${oc_dst#$HOME/}"
        d=$(file_drift "$oc_src" "$oc_dst")
        if [[ -z "$d" ]]; then
            ok_line "$oc_label"
        elif [[ "$d" == missing ]]; then
            fail_line "$oc_label (missing)"
            fixes+=("deploy opencode config|just opencode")
        else
            fail_line "$oc_label ($d)"
            fixes+=("re-deploy opencode config|just opencode")
        fi
    done

    # ── rpm-ostree layered packages (desktop-only: proton-vpn) ─────────
    if (( desktop )); then
    section "rpm-ostree layered packages"
    mapfile -t expected_rpms < <(awk '/^RPM_PACKAGES=\(/,/^\)/' "$here/install-bazzite.sh" | grep -oE '"[^"]+"' | tr -d '"')
    missing_rpms=()
    for pkg in "${expected_rpms[@]}"; do
        rpm -q "$pkg" &>/dev/null || missing_rpms+=("$pkg")
    done
    if (( ${#missing_rpms[@]} == 0 )); then
        ok_line "all ${#expected_rpms[@]} expected packages installed (per RPM_PACKAGES in install-bazzite.sh)"
    else
        fail_line "${#missing_rpms[@]} expected packages not installed (RPM_PACKAGES in install-bazzite.sh):"
        printf '      %s\n' "${missing_rpms[@]}"
        fixes+=("install missing system packages|./install-bazzite.sh $machine")
    fi

    fi  # end desktop-only (rpm-ostree layered packages)

    # ── brewfile ───────────────────────────────────────────────────────
    section "brewfile (Brewfile.$machine)"
    bf="brewfiles/Brewfile.$machine"
    bfd=0

    # Installed lists for type-tagging the brew extras below.
    casks_installed=$(brew list --cask 2>/dev/null || true)
    formulae_installed=$(brew list --formula 2>/dev/null || true)

    # Missing entries (brewfile_missing → TYPE<TAB>NAME<TAB>RAW; drift wants "TYPE NAME").
    declare -a missing_bf=()
    while IFS=$'\t' read -r mtype mname _; do
        missing_bf+=("$mtype $mname")
    done < <(brewfile_missing "$bf")

    bf_missing=0 bf_extras=0
    if (( ${#missing_bf[@]} == 0 )); then
        ok_line "all Brewfile entries installed"
    else
        fail_line "${#missing_bf[@]} Brewfile entries not installed on this machine:"
        printf '      %s\n' "${missing_bf[@]}"
        bf_missing=1
    fi

    # Extras: brew (dependency-aware via brew_cleanup_extras, type-tagged here) +
    # flatpak (installed − Brewfile − ignore-list). All shown with "type name".
    declare -a extras_display=()
    while IFS= read -r pkg; do
        [[ -z "$pkg" ]] && continue
        if echo "$casks_installed" | grep -qFx "$pkg"; then
            extras_display+=("cask $pkg")
        elif echo "$formulae_installed" | grep -qFx "$pkg"; then
            extras_display+=("brew $pkg")
        else
            extras_display+=("? $pkg")
        fi
    done < <(brew_cleanup_extras "$bf")
    while IFS= read -r appid; do
        [[ -n "$appid" ]] && extras_display+=("flatpak $appid")
    done < <(flatpak_extras "$bf" "$here/assets/bazzite-flatpak-ignore.txt")

    if (( ${#extras_display[@]} == 0 )); then
        ok_line "no extras (everything installed is in the Brewfile or in bazzite-flatpak-ignore.txt)"
    else
        fail_line "${#extras_display[@]} packages installed but not in the Brewfile:"
        printf '      %s\n' "${extras_display[@]}"
        bf_extras=1
    fi
    (( bf_missing )) && fixes+=("install Brewfile entries that are missing on this machine|just install-missing $machine")
    (( bf_extras ))  && fixes+=("uninstall packages not in the Brewfile (asks first)|just prune $machine")
    (( bf_missing || bf_extras )) && fixes+=("interactively pick which extras to add and which missing entries to drop from the Brewfile|just reconcile $machine")
    (( bf_missing || bf_extras )) && fixes+=("save this machine's current state to the Brewfile (captures extras, drops missing entries, full overwrite)|just backup $machine")

    # ── desktop-only checks (gnome shell + 1Password + retired PWAs) ───
    if (( desktop )); then

    # ── gnome shell (per-machine dconf snapshot) ───────────────────────
    # Two checks against assets/gnome/shell.<machine>.dconf:
    #   1. Per-machine snapshot exists at all (machines need to be seeded
    #      with `just gnome-backup <m>` once after first sit-down).
    #   2. Live state (filtered the same way gnome-backup filters) matches
    #      the snapshot key-for-key. We don't separately check the shared
    #      shell.dconf — once a machine has a per-machine file, that file
    #      fully owns its state via dconf load order.
    shell_snap_name="shell.$machine.dconf"
    shell_snap="$here/assets/gnome/$shell_snap_name"
    section "gnome shell ($shell_snap_name)"
    shell_drift=0
    if ! command -v dconf >/dev/null 2>&1; then
        ok_line "dconf not available — skipping (non-GNOME session)"
    elif [[ ! -f "$shell_snap" ]]; then
        fail_line "no per-machine snapshot at $shell_snap"
        fixes+=("seed $shell_snap_name from this machine's live GNOME state|just gnome-backup $machine")
        shell_drift=1
    else
        # Re-run the same awk filter `just gnome-backup` uses, diff against
        # the on-disk snapshot. `diff -q` exits non-zero on any difference.
        live_filtered=$(dconf dump /org/gnome/shell/ | awk '
          /^(prefs-opened|extension-version|rounded-blur-found|settings-version|welcome-dialog-last-shown-version|last-version-name-installed|panel-anchors|panel-element-positions|panel-lengths|panel-positions|panel-sizes)=/ { next }
          { print }
        ')
        if diff -q <(echo "$live_filtered") "$shell_snap" >/dev/null 2>&1; then
            ok_line "live state matches $shell_snap_name"
        else
            diff_count=$(diff <(echo "$live_filtered") "$shell_snap" | grep -cE '^[<>]' || true)
            fail_line "$diff_count line(s) differ between live and $shell_snap_name"
            fixes+=("show full diff between live GNOME shell state and the snapshot|diff <(dconf dump /org/gnome/shell/) $shell_snap")
            fixes+=("apply $shell_snap_name to live state (asks first)|just gnome-restore $machine")
            fixes+=("capture this machine's current state into $shell_snap_name|just gnome-backup $machine")
            shell_drift=1
        fi
    fi

    # ── 1Password integration ─────────────────────────────────────────
    # 1Password browser integration has three machine-state requirements
    # that have bitten us multiple times. Surface them here so future drift
    # runs catch regressions before they manifest as "browser unlock just
    # silently doesn't work":
    #   1. User MUST NOT be in the `onepassword` group. The cask creates
    #      the group; setgid exec is the ONLY intended way to obtain that
    #      egid. If the user is a member, IPC peer auth becomes spoofable
    #      and 1P main app rejects connections (PipeAuthError(NoCreds)).
    #   2. /etc/1password/custom_allowed_browsers must contain `vivaldi-bin`,
    #      `zen-bin`, `brave-origin`, and `brave-origin-stable` (the cask
    #      only writes flatpak-session-helper) and be mode 0755 root:root
    #      (writable-only-by-root check; 0444 fails because root has no
    #      write bit).
    #   3. Zen needs its own NMH manifest at ~/.zen/native-messaging-hosts/
    #      — the cask doesn't write one for Zen. Brave Origin needs the
    #      same shape on the Chromium side: a manifest at
    #      ~/.config/BraveSoftware/Brave-Origin/NativeMessagingHosts/
    #      (cask only populates Brave-Browser/'s peer dir, not
    #      Brave-Origin/'s).
    section "1password integration"
    op_drift=0
    if command -v 1password >/dev/null 2>&1; then
        # Group membership check (the most consequential, hardest to debug)
        if id -nG "$USER" | tr ' ' '\n' | grep -qx onepassword; then
            fail_line "user '$USER' is in the 'onepassword' group (BREAKS browser integration)"
            fixes+=("remove user from onepassword group then log out/in|sudo gpasswd -d $USER onepassword")
            op_drift=1
        else
            ok_line "user not in onepassword group"
        fi
        # custom_allowed_browsers presence + perms + entries
        cab=/etc/1password/custom_allowed_browsers
        if [[ ! -f "$cab" ]]; then
            fail_line "$cab missing (1P GUI not installed?)"
            op_drift=1
        else
            cab_mode=$(stat -c %a "$cab")
            cab_owner=$(stat -c %U:%G "$cab")
            if [[ "$cab_mode" != "755" && "$cab_mode" != "644" ]] || [[ "$cab_owner" != "root:root" ]]; then
                fail_line "$cab perms = $cab_mode $cab_owner (need 0755 or 0644 root:root, 1P rejects 0444)"
                op_drift=1
            else
                ok_line "$cab perms ($cab_mode $cab_owner)"
            fi
            cab_missing=()
            for entry in vivaldi-bin zen-bin brave-origin brave-origin-stable; do
                grep -qxF "$entry" "$cab" 2>/dev/null || cab_missing+=("$entry")
            done
            if (( ${#cab_missing[@]} > 0 )); then
                fail_line "$cab missing: ${cab_missing[*]}"
                op_drift=1
            else
                ok_line "$cab contains vivaldi-bin + zen-bin + brave-origin{,-stable}"
            fi
        fi
        # Zen NMH manifest (only if Zen is installed)
        if [[ -d /opt/zen || -d ~/.zen ]]; then
            zen_manifest=~/.zen/native-messaging-hosts/com.1password.1password.json
            if [[ -f "$zen_manifest" ]]; then
                ok_line "Zen NMH manifest present"
            else
                fail_line "Zen installed but no $zen_manifest"
                op_drift=1
            fi
        fi
        # Brave Origin NMH manifest (only if Brave Origin is installed).
        # The cask installs the manifest for Brave-Browser but not for
        # Brave-Origin's config dir; without it the extension's NMH
        # launch fails before 1P's IPC ever sees the connection.
        if [[ -d /opt/brave.com/brave-origin || -d ~/.config/BraveSoftware/Brave-Origin ]]; then
            bo_manifest=~/.config/BraveSoftware/Brave-Origin/NativeMessagingHosts/com.1password.1password.json
            if [[ -f "$bo_manifest" ]]; then
                ok_line "Brave Origin NMH manifest present"
            else
                fail_line "Brave Origin installed but no $bo_manifest"
                op_drift=1
            fi
        fi
        # Quick-access keybinding must invoke 1password by ABSOLUTE path —
        # GNOME shell's PATH is /usr/local/sbin:/usr/local/bin:/usr/bin and
        # does not include the brew prefix where the cask installs the binary.
        # Bare "1password" silently fails to launch when GNOME spawns the
        # keybinding command. Confirm the configured command's first token
        # is an executable file.
        kb_path="/org/gnome/settings-daemon/plugins/media-keys/custom-keybindings/1password/"
        kb_cmd=$(gsettings get "org.gnome.settings-daemon.plugins.media-keys.custom-keybinding:$kb_path" command 2>/dev/null | tr -d "'")
        kb_exe="${kb_cmd%% *}"
        if [[ -z "$kb_cmd" ]]; then
            fail_line "Alt+Shift+2 keybinding not configured"
            op_drift=1
        elif [[ ! -x "$kb_exe" ]]; then
            fail_line "Alt+Shift+2 command resolves to '$kb_exe' which is not executable (GNOME PATH won't find bare names)"
            op_drift=1
        else
            ok_line "Alt+Shift+2 keybinding ($kb_exe)"
        fi
        (( op_drift )) && fixes+=("re-run 1Password per-user config (fixes browser allowlist, Zen NMH, keybinding path)|./install-bazzite.sh $machine")
    else
        ok_line "1Password not installed (skipping integration checks)"
    fi

    # ── retired PWAs ──────────────────────────────────────────────────
    # PWAs that this repo used to deploy via run_config_pwa but have
    # been retired in favor of native apps. The cleanup runs as part
    # of `just install` (run_config_pwa explicitly rm's each one); this
    # check just surfaces the stale state on machines that haven't been
    # re-provisioned since the migration. Add a new stem here whenever
    # a PWA is retired in lockstep with the cleanup list in
    # lib/config.sh.
    section "retired PWAs"
    pwa_apps_dir=~/.local/share/applications
    retired_pwa_stuck=()
    for stem in WebApp-ProtonMail WebApp-ProtonCalendar; do
        [[ -f "$pwa_apps_dir/$stem.desktop" ]] && retired_pwa_stuck+=("$stem.desktop")
    done
    if (( ${#retired_pwa_stuck[@]} > 0 )); then
        fail_line "${#retired_pwa_stuck[@]} retired PWA entries still present:"
        printf '      %s\n' "${retired_pwa_stuck[@]}"
        fixes+=("remove retired PWAs (Proton Mail/Calendar migrated to the proton-mail RPM)|./install-bazzite.sh $machine")
    else
        ok_line "no retired PWAs lingering"
    fi

    fi  # end desktop-only (gnome shell + 1Password + retired PWAs)

    # ── Summary ────────────────────────────────────────────────────────
    section "Summary"
    if (( ${#fixes[@]} == 0 )); then
        ok "Everything in sync."
    else
        for fix in "${fixes[@]}"; do
            action_line "${fix%%|*}" "${fix#*|}"
        done
    fi

# Interactively add extras / drop missing entries from a machine's Brewfile. For each diff item, asks y/N (flatpak extras get y/N/i where i appends to bazzite-flatpak-ignore.txt). Shows a diff and asks for final confirmation before writing.
reconcile machine="":
    #!/usr/bin/env bash
    set -uo pipefail
    source "{{justfile_directory()}}/lib/common.sh"
    machine=$(resolve_machine "Pick a machine (number or name): " "{{machine}}") || { warn "No machine selected, exiting."; exit 0; }
    bf="brewfiles/Brewfile.$machine"
    if [[ ! -f "$bf" ]]; then
        err "$bf not found — run 'just backup $machine' first to create it."
        exit 1
    fi

    here="{{justfile_directory()}}"
    casks_installed=$(brew list --cask 2>/dev/null || true)
    formulae_installed=$(brew list --formula 2>/dev/null || true)

    # Missing entries (brewfile_missing → TYPE<TAB>NAME<TAB>RAW; reconcile keeps RAW).
    declare -a missing_lines=()
    while IFS=$'\t' read -r _ _ raw; do
        missing_lines+=("$raw")
    done < <(brewfile_missing "$bf")

    # Extras: brew (dependency-aware, type-tagged "type|pkg") + flatpak ("flatpak|appid").
    declare -a extras_typed=()
    while IFS= read -r pkg; do
        [[ -z "$pkg" ]] && continue
        if echo "$casks_installed" | grep -qFx "$pkg"; then
            extras_typed+=("cask|$pkg")
        elif echo "$formulae_installed" | grep -qFx "$pkg"; then
            extras_typed+=("brew|$pkg")
        else
            warn "skipping $pkg (can't determine type — not a cask or formula)"
        fi
    done < <(brew_cleanup_extras "$bf")
    while IFS= read -r appid; do
        [[ -n "$appid" ]] && extras_typed+=("flatpak|$appid")
    done < <(flatpak_extras "$bf" "$here/assets/bazzite-flatpak-ignore.txt")

    if (( ${#missing_lines[@]} == 0 && ${#extras_typed[@]} == 0 )); then
        ok "$bf is already in sync. Nothing to reconcile."
        exit 0
    fi

    declare -a to_drop=() to_add=() to_ignore=()
    ignore_file="$here/assets/bazzite-flatpak-ignore.txt"

    if (( ${#missing_lines[@]} > 0 )); then
        section "Brewfile entries NOT installed on this machine"
        echo "  Y = keep tracking in Brewfile (default; you still want this package)"
        echo "  n = drop from Brewfile (you no longer want it tracked)"
        echo
        for line in "${missing_lines[@]}"; do
            name=$(echo "$line" | sed -E 's/^[a-z]+ "([^"]+)".*/\1/')
            printf '  Keep entry "%s" in Brewfile? [Y/n] ' "$name"
            read -r ans
            [[ "$ans" =~ ^[Nn] ]] && to_drop+=("$line")
        done
    fi

    if (( ${#extras_typed[@]} > 0 )); then
        section "Packages installed but NOT in the Brewfile"
        echo "  y = add to Brewfile (track going forward)"
        echo "  i = add to bazzite-flatpak-ignore.txt (silence in drift, flatpaks only)"
        echo "  N = skip (default; leave Brewfile unchanged)"
        echo
        for entry in "${extras_typed[@]}"; do
            type="${entry%%|*}"; pkg="${entry#*|}"
            new_line="$type \"$pkg\""
            if [[ "$type" == "flatpak" ]]; then
                printf '  Add entry "%s" to Brewfile? [y/N/i] ' "$pkg"
            else
                printf '  Add entry "%s" to Brewfile? [y/N] ' "$pkg"
            fi
            read -r ans
            case "$ans" in
                [Yy]*) to_add+=("$new_line") ;;
                [Ii]*)
                    if [[ "$type" == "flatpak" ]]; then
                        to_ignore+=("$pkg")
                    fi
                    ;;
            esac
        done
    fi

    if (( ${#to_drop[@]} == 0 && ${#to_add[@]} == 0 && ${#to_ignore[@]} == 0 )); then
        warn "No changes selected. Nothing modified."
        exit 0
    fi

    new_bf=$(mktemp)
    while IFS= read -r line; do
        skip=0
        for d in "${to_drop[@]}"; do
            [[ "$line" == "$d" ]] && skip=1 && break
        done
        (( skip )) || echo "$line" >> "$new_bf"
    done < "$bf"
    for line in "${to_add[@]}"; do
        echo "$line" >> "$new_bf"
    done

    if (( ${#to_drop[@]} > 0 || ${#to_add[@]} > 0 )); then
        section "Proposed changes to $bf"
        diff -u --label "$bf" --label "$bf (proposed)" "$bf" "$new_bf" || true
    fi
    if (( ${#to_ignore[@]} > 0 )); then
        section "Proposed additions to $ignore_file"
        printf '  + %s\n' "${to_ignore[@]}"
    fi

    echo
    printf 'Apply these changes? [y/N] '
    read -r ans
    if [[ "$ans" =~ ^[Yy] ]]; then
        if (( ${#to_drop[@]} > 0 || ${#to_add[@]} > 0 )); then
            mv "$new_bf" "$bf"
            ok "Updated $bf"
        else
            rm -f "$new_bf"
        fi
        if (( ${#to_ignore[@]} > 0 )); then
            for appid in "${to_ignore[@]}"; do
                echo "$appid" >> "$ignore_file"
            done
            ok "Appended ${#to_ignore[@]} entries to $ignore_file"
        fi
    else
        rm -f "$new_bf"
        warn "Aborted. Nothing modified."
    fi

# Uninstall packages and flatpaks installed on this machine but not listed in the machine's Brewfile. Flatpak extras are filtered through assets/bazzite-flatpak-ignore.txt. Lists what would go, asks first, then runs brew bundle cleanup --force + flatpak uninstall -y.
prune machine="":
    #!/usr/bin/env bash
    set -uo pipefail
    source "{{justfile_directory()}}/lib/common.sh"
    machine=$(resolve_machine "Pick a machine (number or name): " "{{machine}}") || { warn "No machine selected, exiting."; exit 0; }
    bf="brewfiles/Brewfile.$machine"
    require_brewfile "$machine"
    here="{{justfile_directory()}}"

    # Brew side: cleanup dry-run for formula/cask/tap.
    cleanup_out=$(brew bundle cleanup --file="$bf" --formula --cask --tap 2>&1 || true)
    has_brew_extras=0
    echo "$cleanup_out" | grep -qE '^Would uninstall|^[a-z]' && has_brew_extras=1

    # Flatpak side: installed minus Brewfile entries minus ignore list.
    declare -a fp_extras=()
    while IFS= read -r appid; do
        [[ -n "$appid" ]] && fp_extras+=("$appid")
    done < <(flatpak_extras "$bf" "$here/assets/bazzite-flatpak-ignore.txt")

    if (( ! has_brew_extras && ${#fp_extras[@]} == 0 )); then
        ok "Nothing to prune. $bf is in sync with the machine."
        exit 0
    fi

    info "Packages that would be uninstalled (not listed in $bf):"
    if (( has_brew_extras )); then
        echo "$cleanup_out"
    fi
    if (( ${#fp_extras[@]} > 0 )); then
        (( has_brew_extras )) && echo
        echo "Flatpaks:"
        printf '  %s\n' "${fp_extras[@]}"
    fi
    echo
    printf 'Uninstall these packages? [y/N] '
    read -r ans
    if [[ "$ans" =~ ^[Yy] ]]; then
        if (( has_brew_extras )); then
            brew bundle cleanup --file="$bf" --formula --cask --tap --force
        fi
        if (( ${#fp_extras[@]} > 0 )); then
            flatpak uninstall -y "${fp_extras[@]}"
        fi
        ok "Pruned."
    else
        warn "Aborted. Nothing uninstalled."
    fi

# Install Brewfile entries that are missing on this machine (formulas/casks/taps via brew, flatpaks via brew bundle's flatpak directive). Thin wrapper over 'brew bundle install'. Additive — never removes anything.
install-missing machine="":
    #!/usr/bin/env bash
    set -uo pipefail
    export SCRIPT_DIR="{{justfile_directory()}}"
    source "$SCRIPT_DIR/lib/common.sh"
    source "$SCRIPT_DIR/lib/install.sh"
    machine=$(resolve_machine "Pick a machine (number or name): " "{{machine}}") || { warn "No machine selected, exiting."; exit 0; }
    bf="brewfiles/Brewfile.$machine"
    require_brewfile "$machine"
    # Trust third-party taps first so brew bundle can install casks/formulae
    # from ublue-os/tap etc. (Homebrew gates non-official taps behind trust).
    trust_brew_taps "$SCRIPT_DIR/../shared/brew-trusted-taps"
    brew bundle install --file="$bf"

# Set up Zsh with plugins, Starship prompt, and configuration
zsh:
    #!/usr/bin/env bash
    # Install everything the rendered zshrc.template references, so a fully
    # working zsh setup happens whether or not the bazzite-custom image is
    # in use. On image-rebased machines this means duplicates (brew copy
    # of bat/eza/etc. alongside the image RPM at /usr/bin) — accepted
    # because (a) brew typically wins in PATH ordering after brew shellenv,
    # (b) brewfile listing them keeps `just drift`/`just prune` consistent,
    # (c) the disk cost is small. Stock-Bazzite users run this and get a
    # complete shell with no image dependency.
    # Trust third-party taps before installing — sesh (and any future zsh tool)
    # may resolve to a tap rather than homebrew/core; Homebrew 5.2+ blocks
    # untrusted taps. Uses the shared brew-trust list (see lib/install.sh).
    export SCRIPT_DIR="{{justfile_directory()}}"
    source "$SCRIPT_DIR/lib/common.sh"
    source "$SCRIPT_DIR/lib/install.sh"
    trust_brew_taps "$SCRIPT_DIR/../shared/brew-trusted-taps"
    echo "Installing Zsh plugins + CLI baseline + brew-only tools..."
    brew install \
        zsh-autosuggestions \
        zsh-syntax-highlighting \
        zsh-autopair \
        zsh-completions \
        zsh-history-substring-search \
        zsh-you-should-use \
        bat \
        eza \
        fzf \
        fzf-tab \
        zoxide \
        starship \
        tmux \
        lazygit \
        sesh \
        claude-code \
        jq

    # Migrate native Claude Code install to Homebrew
    if [[ -f "$HOME/.local/bin/claude" ]]; then
        echo "Migrating Claude Code from native to Homebrew..."
        rm -f "$HOME/.local/bin/claude"
        if [[ -f "$HOME/.claude.json" ]]; then
            jq '.installMethod = "brew"' "$HOME/.claude.json" > "$HOME/.claude.json.tmp" \
                && mv "$HOME/.claude.json.tmp" "$HOME/.claude.json"
        fi
        echo "Native Claude Code removed — now managed by Homebrew"
    fi

    # Silence zoxide's doctor warning inside Claude Code's Bash tool. The
    # tool replays a cached shell snapshot (~/.claude/shell-snapshots/) that
    # captures function bodies + PATH but NOT other env vars, and skips
    # zoxide's `add-zsh-hook chpwd __zoxide_hook` side-effect. So
    # __zoxide_doctor fires on every command and prints the misleading
    # "init zoxide last in ~/.zshrc" message. Setting _ZO_DOCTOR=0 in
    # Claude Code's own env makes the doctor short-circuit regardless of
    # what the snapshot captured.
    mkdir -p "$HOME/.claude"
    settings="$HOME/.claude/settings.json"
    [[ -f "$settings" ]] || echo '{}' > "$settings"
    if [[ "$(jq -r '.env._ZO_DOCTOR // ""' "$settings")" != "0" ]]; then
        jq '.env._ZO_DOCTOR = "0"' "$settings" > "$settings.tmp" \
            && mv "$settings.tmp" "$settings"
        echo "Set _ZO_DOCTOR=0 in $settings (silences zoxide doctor in Claude Code)"
    fi

    # All four Nerd Fonts: the symbols-only one is also in the image as
    # `nerd-fonts` RPM, but listing it here keeps stock-Bazzite users covered
    # and matches the brewfile (avoids prune cycle).
    echo "Installing Nerd Fonts..."
    brew install \
        font-symbols-only-nerd-font \
        font-fira-code-nerd-font \
        font-hack-nerd-font \
        font-meslo-lg-nerd-font

    echo "Configuring Nerd Font symbol fallback..."
    mkdir -p ~/.config/fontconfig/conf.d
    curl -fsSL https://raw.githubusercontent.com/ryanoasis/nerd-fonts/master/10-nerd-font-symbols.conf \
        -o ~/.config/fontconfig/conf.d/10-nerd-font-symbols.conf
    fc-cache -f

    # ── Two-file model for .zshrc (added 2026-05) ─────────────────────────
    # ~/.zshrc.image — auto-managed, rewritten on every `just zsh` from
    #                  assets/zshrc.template. Drift checks this file.
    # ~/.zshrc       — yours to edit. Initial bootstrap written ONCE if
    #                  it doesn't yet exist or still has the old template
    #                  content. Tools like nvm/bun/pyenv that auto-modify
    #                  .zshrc no longer get clobbered on the next `just zsh`,
    #                  and template updates land in .zshrc.image without
    #                  touching your customizations.
    brew_prefix="$(brew --prefix)"
    chmod -R go-w "$brew_prefix/share" "$brew_prefix/share/zsh" 2>/dev/null || true

    # Always rewrite the managed file from template (with BREW_PREFIX subst).
    sed "s|BREW_PREFIX|$brew_prefix|g" "{{justfile_directory()}}/assets/zshrc.template" > ~/.zshrc.image
    echo "Updated ~/.zshrc.image (managed)"

    # Bootstrap ~/.zshrc only if it's missing OR doesn't yet have the
    # `source ~/.zshrc.image` line. Anything containing that line is treated
    # as a post-migration user file and left untouched. Pre-migration files
    # (the old full-template content) get backed up and replaced.
    needs_bootstrap=0
    if [[ ! -f ~/.zshrc ]] || ! grep -qF 'source ~/.zshrc.image' ~/.zshrc; then
        needs_bootstrap=1
    fi
    if (( needs_bootstrap )); then
        if [[ -f ~/.zshrc ]]; then
            cp ~/.zshrc ~/.zshrc.bak
            echo "Backed up existing .zshrc to .zshrc.bak"
        fi
        cp "{{justfile_directory()}}/assets/zshrc-bootstrap" ~/.zshrc
        echo "Wrote bootstrap ~/.zshrc → sources ~/.zshrc.image"
    else
        echo "~/.zshrc has user content, leaving as-is (must contain 'source ~/.zshrc.image')"
    fi

    # ~/.zshrc.local was the per-machine override file under the old single-
    # file model. Decommissioned 2026-05: per-machine settings now live in
    # ~/.zshrc (user-owned). Warn on its presence so the user migrates.
    if [[ -f ~/.zshrc.local ]]; then
        echo ""
        echo "⚠️  ~/.zshrc.local exists but is no longer sourced (decommissioned)."
        echo "   Move its content into ~/.zshrc, then 'rm ~/.zshrc.local'."
        echo ""
    fi

    mkdir -p ~/.config
    cp "{{justfile_directory()}}/../shared/starship.toml" ~/.config/starship.toml
    cp "{{justfile_directory()}}/../shared/tmux.conf" ~/.tmux.conf

    echo "Setting up tmux plugin manager..."
    if [[ -d ~/.tmux/plugins/tpm ]]; then
        git -C ~/.tmux/plugins/tpm pull -q
    else
        git clone -q https://github.com/tmux-plugins/tpm ~/.tmux/plugins/tpm
    fi
    ~/.tmux/plugins/tpm/bin/install_plugins
    ~/.tmux/plugins/tpm/bin/update_plugins all

    echo "Cleaning up old Powerlevel10k artifacts..."
    rm -f ~/.p10k.zsh
    rm -f "${XDG_CACHE_HOME:-$HOME/.cache}"/p10k-instant-prompt-*.zsh
    brew uninstall powerlevel10k 2>/dev/null || true
    brew untap romkatv/powerlevel10k 2>/dev/null || true

    if [[ "$(basename "$SHELL")" != "zsh" ]]; then
        echo "Setting Zsh as default shell..."
        chsh -s "$(which zsh)"
    fi

    echo "Configuring Git..."
    git config --global user.name "Jakob Hviid, PhD"
    git config --global user.email "jakob@hviid.phd"
    git config --global pull.rebase true

    echo "✓ Zsh setup complete"
    echo "  Run 'exec zsh' to load changes"

# Import finalized speaker-EQ profiles from the pipewire-speaker-calibration repo
# (the calibration "lab") into assets/speaker-eq/. Clones the lab via SSH beside
# this repo if it isn't checked out, else fast-forwards it, then copies every
# calibrated/*.conf in. The dependency lives HERE (the consumer) — the lab knows
# nothing about us. Review + commit the result, then `just speaker-eq` installs.
# Override the lab location with SPEAKER_EQ_LAB=/path.
eq-import:
    #!/usr/bin/env bash
    set -uo pipefail
    source "{{justfile_directory()}}/lib/common.sh"
    lab="${SPEAKER_EQ_LAB:-$(cd "{{justfile_directory()}}/../.." && pwd)/pipewire-speaker-calibration}"
    ssh_url="git@github.com:jakobhviid/pipewire-speaker-calibration.git"
    if [[ ! -d "$lab/.git" ]]; then
        warn "pipewire-speaker-calibration not checked out at $lab"
        info "Cloning it via SSH…"
        git clone "$ssh_url" "$lab" || { err "Clone failed (SSH key / access?)."; exit 1; }
    else
        info "Updating $(basename "$lab")…"
        git -C "$lab" pull --ff-only 2>/dev/null || warn "Couldn't fast-forward; using the current checkout."
    fi
    src="$lab/calibrated"; dst="{{justfile_directory()}}/assets/speaker-eq"
    [[ -d "$src" ]] || { err "No calibrated/ folder in the lab checkout."; exit 1; }
    mkdir -p "$dst"; n=0; shopt -s nullglob
    for f in "$src"/*.conf; do cp "$f" "$dst/"; ok "imported $(basename "$f" .conf)"; n=$((n+1)); done
    [[ $n -gt 0 ]] || { warn "No calibrated profiles to import yet."; exit 0; }
    info "Imported $n profile(s). Review + commit assets/speaker-eq/, then: just speaker-eq"

# Install a PipeWire filter-chain speaker EQ. Profiles live in assets/speaker-eq/
# — one .conf per physical speaker, each with its own node name so more than one
# can be active at once (e.g. a docked laptop using both its internal speakers
# AND the monitor's). Each profile carries a "# target-match:" pattern instead of
# a hardcoded sink: the recipe finds the matching sink NOW (by monitor EDID name,
# node.name, etc.) and bakes its real node.name into node.target — so the DELL
# profile works whether the monitor is on the desktop's HDMI or the laptop's
# Thunderbolt/DisplayPort, which have different sink names. With no argument it
# lists profiles and defaults to whichever one's target is connected; pass a name
# to install one, or 'all'. Re-runnable: each profile deploys to its own
# speaker-eq-<profile>.conf, so installing one never removes another.
speaker-eq profile="":
    #!/usr/bin/env bash
    set -uo pipefail
    source "{{justfile_directory()}}/lib/common.sh"
    is_desktop || { warn "speaker-eq is desktop-only (needs PipeWire + a graphical session) — skipping on this headless host."; exit 0; }

    src="{{justfile_directory()}}/assets/speaker-eq"
    dst="$HOME/.config/pipewire/pipewire.conf.d"
    [[ -d "$src" ]] || { err "No speaker-eq profiles directory at $src"; exit 1; }

    # Available profiles = basenames of assets/speaker-eq/*.conf
    profiles=()
    for f in "$src"/*.conf; do [[ -e "$f" ]] && profiles+=("$(basename "$f" .conf)"); done
    [[ ${#profiles[@]} -gt 0 ]] || { err "No .conf profiles found in $src"; exit 1; }

    # A profile's "# target-match:" pattern (what sink it should route to).
    match_of() { sed -nE 's/^#[[:space:]]*target-match:[[:space:]]*(.+[^[:space:]])[[:space:]]*$/\1/p' "$src/$1.conf" | head -1; }
    # Sink node.name(s) whose full pactl block matches a case-insensitive pattern.
    # Matching on the whole block picks up node.nick / alsa.name (monitor EDID name)
    # as well as node.name, so it's portable across GPUs/buses. Our own effect_*
    # virtual sinks are excluded — their description carries the monitor name too,
    # which would otherwise let a profile match (and target) itself.
    resolve_sink() { pactl list sinks 2>/dev/null | awk -v pat="$1" 'BEGIN{RS=""} tolower($0) ~ tolower(pat) { if (match($0,/Name: [^\n]+/)) { n=substr($0,RSTART+6,RLENGTH-6); if (n !~ /^effect_(input|output)\./) print n } }'; }

    # Default to the first profile whose target sink is connected right now.
    default=""
    for p in "${profiles[@]}"; do
        m=$(match_of "$p"); [[ -n "$m" ]] || continue
        if [[ -n "$(resolve_sink "$m")" ]]; then info "Connected speaker detected → profile '$p'"; default="$p"; break; fi
    done

    # Resolve selection: recipe argument, else interactive picker (with an 'all' option).
    sel="{{profile}}"
    [[ -z "$sel" ]] && sel=$(pick_choice "Pick a speaker profile (or 'all'): " "$default" "${profiles[@]}" "all")
    [[ -n "$sel" ]] || { warn "Nothing selected, exiting."; exit 0; }

    to_install=()
    if [[ "$sel" == "all" ]]; then
        to_install=("${profiles[@]}")
    else
        [[ -f "$src/$sel.conf" ]] || { err "Unknown profile '$sel'. Available: ${profiles[*]} (or 'all')"; exit 1; }
        to_install=("$sel")
    fi

    mkdir -p "$dst"
    # Migrate off the old single-file layout — its node name collides with the
    # thinkpad-x1carbon profile's, so leaving it would load the filter twice.
    if [[ -f "$dst/speaker-eq.conf" ]]; then warn "Removing legacy $dst/speaker-eq.conf (superseded by per-profile files)"; rm -f "$dst/speaker-eq.conf"; fi

    # Deploy each selected profile, resolving its target sink and baking it in.
    installed=()
    for p in "${to_install[@]}"; do
        m=$(match_of "$p")
        if [[ -z "$m" ]]; then err "Profile '$p' has no '# target-match:' line — skipping."; continue; fi
        mapfile -t hits < <(resolve_sink "$m")
        if [[ ${#hits[@]} -eq 0 ]]; then
            err "No sink matches '$m' for profile '$p' — is that speaker/monitor connected? Skipping."
            echo "     Connected sinks:"; pactl list short sinks | awk '{print "       " $2}'
            continue
        elif [[ ${#hits[@]} -eq 1 ]]; then
            target="${hits[0]}"
        else
            info "Profile '$p' matches several sinks — pick the target:"
            target=$(pick_choice "Target sink for '$p': " "${hits[0]}" "${hits[@]}")
        fi
        [[ -n "$target" ]] || { warn "No target chosen for '$p' — skipping."; continue; }
        sed -e "s|__TARGET_SINK__|$target|" "$src/$p.conf" > "$dst/speaker-eq-$p.conf"
        ok "Installed '$p' → $target"
        installed+=("$p")
    done
    [[ ${#installed[@]} -gt 0 ]] || { err "Nothing installed."; exit 1; }

    info "Restarting PipeWire..."
    systemctl --user restart pipewire pipewire-pulse
    sleep 1

    # Make the last-installed profile the default output.
    last_node=""
    for p in "${installed[@]}"; do
        desc=$(grep -oE 'node\.description[[:space:]]*=[[:space:]]*"[^"]+"' "$src/$p.conf" | sed -E 's/.*"([^"]+)".*/\1/')
        printf '  • %-20s → "%s"\n' "$p" "$desc"
        last_node=$(grep -oE 'effect_input\.[A-Za-z0-9_]+' "$src/$p.conf" | head -1)
    done
    if [[ -n "$last_node" ]]; then
        node_id=$(wpctl status 2>/dev/null | grep "$last_node" | head -1 | grep -o '[0-9]\+' | head -1)
        if [[ -n "$node_id" ]]; then wpctl set-default "$node_id"; ok "Default output set to node $node_id ($last_node)"
        else warn "Filter loaded but couldn't find its node ID — pick the EQ output in sound settings"; fi
    fi

# Snapshot GNOME shell settings to assets/gnome/shell.<machine>.dconf — full /org/gnome/shell/ state minus transient bookkeeping and per-monitor panel keys.
gnome-backup machine="":
    #!/usr/bin/env bash
    set -uo pipefail
    source "{{justfile_directory()}}/lib/common.sh"
    if ! command -v gnome-shell >/dev/null 2>&1; then
        warn "gnome-backup is desktop-only (no gnome-shell on this host) — nothing to snapshot."
        exit 0
    fi
    machine=$(resolve_machine "Pick a machine (number, name, or new name): " "{{machine}}" create) || { warn "No machine selected, exiting."; exit 0; }
    out="{{justfile_directory()}}/assets/gnome/shell.${machine}.dconf"
    mkdir -p "$(dirname "$out")"
    # Full /org/gnome/shell/ dump — keep every section (including [/] so
    # enabled-extensions is captured). Drop two key classes that don't
    # belong in committed snapshots:
    #   - bookkeeping keys GNOME rewrites on its own
    #   - per-monitor panel keys encoding display connector IDs; rewritten
    #     transiently on monitor plug/unplug, so a backup→restore cycle on
    #     the same machine can land the wrong values
    dconf dump /org/gnome/shell/ | awk '
      /^(prefs-opened|extension-version|rounded-blur-found|settings-version|welcome-dialog-last-shown-version|last-version-name-installed|panel-anchors|panel-element-positions|panel-lengths|panel-positions|panel-sizes)=/ { next }
      { print }
    ' > "$out"
    echo "✓ Wrote $out ($(wc -l < "$out") lines)"

# Add this machine's live enabled-extensions to the shared shell.dconf seed (union — never removes). Use this when you've installed a new extension and want it picked up on next install across all machines. Per-machine snapshots still win for any machine that has explicitly overridden enabled-extensions in its own file.
extensions-sync:
    #!/usr/bin/env bash
    set -uo pipefail
    source "{{justfile_directory()}}/lib/common.sh"
    if ! command -v gnome-shell >/dev/null 2>&1; then
        warn "extensions-sync is desktop-only (no gnome-shell on this host) — skipping."
        exit 0
    fi
    shared="{{justfile_directory()}}/assets/gnome/shell.dconf"
    if ! command -v dconf >/dev/null 2>&1; then
        err "dconf not available"
        exit 1
    fi
    live_raw=$(dconf read /org/gnome/shell/enabled-extensions 2>/dev/null || echo "[]")
    live_uuids=$(echo "$live_raw" | grep -oE "'[^']+'" | tr -d "'" | sort -u)
    shared_uuids=""
    if [[ -f "$shared" ]]; then
        shared_uuids=$(awk '
          /^\[\/\]/ { root=1; next }
          /^\[/ && !/^\[\/\]/ { root=0; next }
          root && /^enabled-extensions=/ { print; exit }
        ' "$shared" | grep -oE "'[^']+'" | tr -d "'" | sort -u)
    fi
    additions=$(comm -23 <(echo "$live_uuids") <(echo "$shared_uuids") | grep -v '^$' || true)
    if [[ -z "$additions" ]]; then
        ok "shared shell.dconf already has every extension enabled on this machine"
        exit 0
    fi
    echo "Adding to shared shell.dconf:"
    echo "$additions" | sed 's/^/  + /'
    union=$(printf "%s\n%s\n" "$live_uuids" "$shared_uuids" | sort -u | grep -v '^$')
    new_line="enabled-extensions=[$(echo "$union" | sed "s/^/'/;s/$/'/" | paste -sd',' -)]"
    if [[ ! -f "$shared" ]]; then
        printf '[/]\n%s\n' "$new_line" > "$shared"
    elif grep -q '^enabled-extensions=' "$shared"; then
        awk -v repl="$new_line" '
          !done && /^enabled-extensions=/ { print repl; done=1; next }
          { print }
        ' "$shared" > "$shared.tmp" && mv "$shared.tmp" "$shared"
    elif grep -q '^\[/\]' "$shared"; then
        awk -v line="$new_line" '
          /^\[\/\]/ { print; print line; next }
          { print }
        ' "$shared" > "$shared.tmp" && mv "$shared.tmp" "$shared"
    else
        { printf '[/]\n%s\n\n' "$new_line"; cat "$shared"; } > "$shared.tmp" && mv "$shared.tmp" "$shared"
    fi
    ok "Updated $shared"

# Snapshot Ptyxis settings (profiles, shortcuts, window prefs) to assets/ptyxis.dconf.
ptyxis-backup:
    #!/usr/bin/env bash
    set -euo pipefail
    if ! command -v gnome-shell >/dev/null 2>&1; then
        echo "ptyxis-backup is desktop-only (no gnome-shell on this host) — skipping."
        exit 0
    fi
    out="{{justfile_directory()}}/assets/ptyxis.dconf"
    mkdir -p "$(dirname "$out")"
    dconf dump /org/gnome/Ptyxis/ > "$out"
    echo "✓ Wrote $out ($(wc -l < "$out") lines)"

# Load shared assets/gnome/shell.dconf then per-machine assets/gnome/shell.<machine>.dconf into live /org/gnome/shell/. Asks first, default no — overwrites GNOME shell prefs.
gnome-restore machine="":
    #!/usr/bin/env bash
    set -uo pipefail
    source "{{justfile_directory()}}/lib/common.sh"
    if ! command -v gnome-shell >/dev/null 2>&1; then
        warn "gnome-restore is desktop-only (no gnome-shell on this host) — skipping."
        exit 0
    fi
    machine=$(resolve_machine "Pick a machine (number or name): " "{{machine}}") || { warn "No machine selected, exiting."; exit 0; }
    shared="{{justfile_directory()}}/assets/gnome/shell.dconf"
    per_machine="{{justfile_directory()}}/assets/gnome/shell.${machine}.dconf"
    if [[ ! -f "$shared" && ! -f "$per_machine" ]]; then
        err "Neither $shared nor $per_machine found"
        exit 1
    fi
    plan=()
    [[ -f "$shared" ]] && plan+=("$shared ($(wc -l < "$shared") lines, shared seed)")
    [[ -f "$per_machine" ]] && plan+=("$per_machine ($(wc -l < "$per_machine") lines, per-machine)")
    warn "About to load into /org/gnome/shell/:"
    printf '      %s\n' "${plan[@]}"
    warn "Shared loads first, per-machine overrides any keys it also sets (including enabled-extensions if present)."
    if confirm "Apply?"; then
        [[ -f "$shared" ]] && dconf load /org/gnome/shell/ < "$shared"
        [[ -f "$per_machine" ]] && dconf load /org/gnome/shell/ < "$per_machine"
        ok "Applied $machine snapshot stack"
    else
        info "Aborted."
    fi

# Apply assets/ptyxis.dconf to live /org/gnome/Ptyxis/. Asks first, default no — overwrites Ptyxis prefs.
ptyxis-restore:
    #!/usr/bin/env bash
    set -uo pipefail
    source "{{justfile_directory()}}/lib/common.sh"
    if ! command -v gnome-shell >/dev/null 2>&1; then
        warn "ptyxis-restore is desktop-only (no gnome-shell on this host) — skipping."
        exit 0
    fi
    snapshot="{{justfile_directory()}}/assets/ptyxis.dconf"
    if [[ ! -f "$snapshot" ]]; then
        err "$snapshot not found"
        exit 1
    fi
    warn "About to load $(wc -l < "$snapshot") lines of dconf state into /org/gnome/Ptyxis/"
    warn "This overwrites your live Ptyxis prefs (profiles, keybindings, window prefs)."
    if confirm "Apply snapshot?"; then
        dconf load /org/gnome/Ptyxis/ < "$snapshot"
        ok "Applied $snapshot"
    else
        info "Aborted."
    fi

