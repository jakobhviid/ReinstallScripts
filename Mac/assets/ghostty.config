# Ghostty config — translated from iTerm2 "Default" profile (dark-mode colors)
# Generated 2026-05-22

# ── Font ─────────────────────────────────────────────────────────────
# Using Ghostty defaults (JetBrains Mono, size 13 on macOS).
#
# Re-enable `dlig` (discretionary ligatures). Ghostty 1.2.0 disabled it by
# default, which broke arrow ligatures (->, =>, <-, <=) in JetBrains Mono
# since the font puts them in dlig, not in calt.
font-feature = dlig

# ── Background transparency + blur (matches iTerm2 Transparency 0.160, Blur 24) ──
background-opacity = 0.84
background-blur-radius = 24

# Initial window size in terminal cells (columns × rows). Only affects newly
# created windows, not existing ones, splits, or tabs. Pinned so windows
# always open at a predictable size instead of whatever the OS last remembered.
window-width = 132
window-height = 36

# ── Cursor ───────────────────────────────────────────────────────────
cursor-style = bar
cursor-style-blink = true
cursor-color = ffffff
cursor-text = 000000

# ── Core colors ──────────────────────────────────────────────────────
background = 15191f
foreground = dcdcdc
selection-background = b3d7ff
selection-foreground = 000000

# ── 16-color ANSI palette ────────────────────────────────────────────
palette = 0=#14191e
palette = 1=#eb5032
palette = 2=#3bea06
palette = 3=#c7c400
palette = 4=#3f5bff
palette = 5=#e44dee
palette = 6=#00c5c7
palette = 7=#c7c7c7
palette = 8=#686868
palette = 9=#dd7975
palette = 10=#58e790
palette = 11=#ece100
palette = 12=#a7abf2
palette = 13=#e786f0
palette = 14=#60fdff
palette = 15=#ffffff

# ── Window chrome ────────────────────────────────────────────────────
window-padding-x = 10
# window-padding-y format: "TOP,BOTTOM" — top tightened to 4 to sit closer
# under the titlebar; bottom kept at 8.
window-padding-y = 4,8
window-padding-balance = true
# Tabs merged into the titlebar (Safari/Chrome style). One bar instead of
# two — saves vertical pixels. With a single tab, the title sits inline
# with the traffic-light buttons. Multiple tabs show as actual tabs.
macos-titlebar-style = tabs
# Hide the folder ("proxy") icon next to the title in the titlebar.
# (Belt-and-suspenders: the tabs style also tends to hide it implicitly.)
macos-titlebar-proxy-icon = hidden

# ── macOS behavior ───────────────────────────────────────────────────
# Left Option acts as the Alt/Meta key (vim word-jumps, zsh meta-bindings,
# emacs everything). Right Option still types special characters (å/æ/ø
# on Danish layouts) so writing Danish in the terminal still works.
macos-option-as-alt = left

# Auto-update channel: notify when an update is available, then prompt
# before installing (instead of the default "download silently" behavior).
auto-update = check

# ── Quick Terminal (quake-style dropdown) ────────────────────────────
# Hotkey: ctrl + escape.
#
# Why not cmd+escape: confirmed unreliable on recent macOS 26.x; the OS
# intercepts it. See:
#   https://github.com/ghostty-org/ghostty/discussions/11829
#   https://github.com/ghostty-org/ghostty/issues/7215
# The 26.x bug is specific to cmd+escape; ctrl+escape is not affected.
#
# Why not cmd+$ (the Danish §-key): Ghostty's inspector reports kVK_ISO_Section
# as "unidentified" — no Ghostty key name maps to it. macOS also reserves
# cmd+§ for "cycle windows in current app" on Danish layouts.
#
# Note: requires Accessibility permission. Ghostty does NOT support `fn`/globe
# as a modifier (OS-level limitation).
keybind = global:ctrl+escape=toggle_quick_terminal

# Global "new normal Ghostty window" hotkey. Matches the long-standing Linux
# desktop convention (GNOME/Ubuntu/Mint default: Ctrl+Alt+T from anywhere
# opens a new terminal). Cmd+N is still the in-app shortcut for new window.
keybind = global:ctrl+alt+t=new_window
quick-terminal-position = left
# Width: 1000 px. At JetBrains Mono 13pt that's ~128 columns. Tune to taste:
#   720px ≈ strict half of a 1440-wide laptop
#   1000px ≈ ~58% of 14" MacBook (still well under 1/3 of a 3440 ultrawide)
#   1150px ≈ 1/3 of a 3440 ultrawide
quick-terminal-size = 1000px
quick-terminal-animation-duration = 0.2
quick-terminal-screen = mouse
quick-terminal-autohide = true

# ── Misc niceties ────────────────────────────────────────────────────
copy-on-select = clipboard
mouse-hide-while-typing = true
confirm-close-surface = false

# Auto-allow programs to READ the system clipboard via OSC 52 escape
# sequences (used by neovim/tmux yank-over-SSH, etc.). Default is `ask`,
# which interrupts the flow with a dialog every time. Write is already
# `allow` by default. Mild loosening — any program with stdout can stuff
# requests at your clipboard. Personal-laptop appropriate.
clipboard-read = allow

# Cmd+Q safety: require pressing cmd+Q twice in a row to actually quit.
# Single accidental cmd+Q does nothing — Ghostty stays open. There's no
# separate `confirm-quit` option in Ghostty, so this is the workaround.
keybind = cmd+q=unbind
keybind = cmd+q>cmd+q=quit

# Click-link to follow: enabled. cmd+click on URLs (https://, file://, etc.)
# in the terminal opens them in the default app. NOTE: plain folder paths
# like /Users/jakob/foo are NOT matched by default — they need a custom
# `link = ...` regex. file:// URIs do work out of the box.
link-url = true
link-previews = true

# ── SSH integration ──────────────────────────────────────────────────
# Ghostty sets TERM=xterm-ghostty, which most remote hosts don't have a
# terminfo entry for — leading to `tput: unknown terminal` errors, broken
# arrow keys, garbled vim/htop, etc. These two flags wrap the `ssh` command
# so Ghostty copies its terminfo to the remote on first connect (ssh-terminfo)
# and forwards a few env vars like COLORTERM (ssh-env). Setting is additive —
# does not disable cursor/title/path defaults.
shell-integration-features = ssh-env,ssh-terminfo
