# Mac setup recipes — run from the Mac/ directory

# List available machines (Brewfile.* without the prefix)
_machines := `ls Brewfile.* 2>/dev/null | sed 's/Brewfile\.//' | tr '\n' ' '`

# List available profiles (*.mobileconfig without the extension)
_profiles := `ls *.mobileconfig 2>/dev/null | sed 's/\.mobileconfig//' | tr '\n' ' '`

# Show available commands
default:
    @echo "Mac setup — run from the Mac/ directory"
    @echo ""
    @echo "Commands:"
    @echo "  just install [machine]    Install Homebrew packages from a machine's Brewfile"
    @echo "  just backup [machine]     Dump current Homebrew state to a Brewfile (or create new)"
    @echo "  just cleanup [machine]    Uninstall packages not listed in a machine's Brewfile"
    @echo "  just profile [name]       Install a macOS configuration profile (.mobileconfig)"
    @echo "  just zsh                  Set up Zsh with plugins, Starship prompt, and config"
    @echo ""
    @echo "Available machines: {{_machines}}"
    @echo "Available profiles: {{_profiles}}"

# Install Homebrew packages from a machine's Brewfile
install machine="":
    #!/usr/bin/env zsh
    machine="{{machine}}"
    if [[ -z "$machine" ]]; then
        choices=( $(ls Brewfile.* 2>/dev/null | sed 's/Brewfile\.//') )
        echo "Available machines:"
        for i in {1..${#choices[@]}}; do echo "  $i) $choices[$i]"; done
        echo -n "Pick a machine (number or name): "
        read choice
        if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#choices[@]} )); then
            machine="$choices[$choice]"
        else
            machine="$choice"
        fi
    fi
    if [[ -z "$machine" ]]; then
        echo "No machine selected, exiting."
        exit 0
    fi
    if [[ ! -f "Brewfile.$machine" ]]; then
        echo "Error: Brewfile.$machine not found"
        exit 1
    fi
    echo "Installing from Brewfile.$machine..."
    brew bundle --file="Brewfile.$machine"

    just zsh
    just profile brave-debloat

# Dump current Homebrew state to a Brewfile (or create a new one)
backup machine="":
    #!/usr/bin/env zsh
    machine="{{machine}}"
    if [[ -z "$machine" ]]; then
        choices=( $(ls Brewfile.* 2>/dev/null | sed 's/Brewfile\.//') )
        echo "Existing machines:"
        for i in {1..${#choices[@]}}; do echo "  $i) $choices[$i]"; done
        echo -n "Pick a machine (number, name, or new name): "
        read choice
        if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#choices[@]} )); then
            machine="$choices[$choice]"
        else
            machine="$choice"
        fi
    fi
    if [[ -z "$machine" ]]; then
        echo "No machine selected, exiting."
        exit 0
    fi
    if [[ -f "Brewfile.$machine" ]]; then
        echo "Overwriting Brewfile.$machine..."
    else
        echo "Creating new Brewfile.$machine..."
    fi
    brew bundle dump --file="Brewfile.$machine" --force
    echo "Done. Saved to Brewfile.$machine"

# Install a macOS configuration profile (.mobileconfig)
profile name="":
    #!/usr/bin/env zsh
    name="{{name}}"
    if [[ -z "$name" ]]; then
        choices=( $(ls *.mobileconfig 2>/dev/null | sed 's/\.mobileconfig//') )
        echo "Available profiles:"
        for i in {1..${#choices[@]}}; do echo "  $i) $choices[$i]"; done
        echo -n "Pick a profile (number or name): "
        read choice
        if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#choices[@]} )); then
            name="$choices[$choice]"
        else
            name="$choice"
        fi
    fi
    if [[ -z "$name" ]]; then
        echo "No profile selected, exiting."
        exit 0
    fi
    file="${name}.mobileconfig"
    if [[ ! -f "$file" ]]; then
        echo "Error: $file not found"
        exit 1
    fi
    echo "Installing profile $file..."
    open "$file"

# Uninstall packages not listed in a machine's Brewfile
cleanup machine="":
    #!/usr/bin/env zsh
    machine="{{machine}}"
    if [[ -z "$machine" ]]; then
        choices=( $(ls Brewfile.* 2>/dev/null | sed 's/Brewfile\.//') )
        echo "Available machines:"
        for i in {1..${#choices[@]}}; do echo "  $i) $choices[$i]"; done
        echo -n "Pick a machine (number or name): "
        read choice
        if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#choices[@]} )); then
            machine="$choices[$choice]"
        else
            machine="$choice"
        fi
    fi
    if [[ -z "$machine" ]]; then
        echo "No machine selected, exiting."
        exit 0
    fi
    if [[ ! -f "Brewfile.$machine" ]]; then
        echo "Error: Brewfile.$machine not found"
        exit 1
    fi
    output=$(brew bundle cleanup --file="Brewfile.$machine" 2>&1)
    if [[ -z "$output" ]]; then
        echo "Brewfile.$machine is in sync — nothing to clean up."
        exit 0
    fi
    section=""
    echo "Not in Brewfile.$machine:"
    echo "$output" | while IFS= read -r line; do
        if [[ "$line" == "Would uninstall casks:"* ]]; then
            section="casks"; echo ""; echo "  Casks:"
        elif [[ "$line" == "Would uninstall formulae:"* ]]; then
            section="formulae"; echo ""; echo "  Formulae:"
        elif [[ "$line" == "Would uninstall VSCode"* ]]; then
            section="vscode"; echo ""; echo "  VS Code extensions:"
        elif [[ "$line" == "Would \`brew cleanup\`:"* ]]; then
            section="cache"; echo ""; echo "  Cached files:"
        elif [[ "$line" == "Run \`brew"* || "$line" == "Run "* ]]; then
            continue
        elif [[ -n "$section" && -n "$line" ]]; then
            if [[ "$section" == "cache" ]]; then
                if [[ "$line" == "Would remove:"* ]]; then
                    echo "    ${line#Would remove: }"
                fi
            else
                for word in ${=line}; do
                    echo "    $word"
                done
            fi
        fi
    done
    echo ""
    echo "To uninstall these:"
    echo "  brew bundle cleanup --file=Brewfile.$machine --force"

# Set up Zsh with plugins, Starship prompt, and configuration
zsh:
    #!/usr/bin/env zsh
    echo "Installing Zsh plugins and CLI tools via Homebrew..."
    brew tap joshmedeski/sesh 2>/dev/null || true
    brew install \
        zsh-autosuggestions \
        zsh-syntax-highlighting \
        zsh-completions \
        zsh-history-substring-search \
        zsh-autopair \
        zsh-you-should-use \
        bat \
        eza \
        fzf \
        fzf-tab \
        zoxide \
        starship \
        tmux \
        lazygit \
        sesh \
        claude-code \
        jq

    # Migrate native Claude Code install to Homebrew
    if [[ -f "$HOME/.local/bin/claude" ]]; then
        echo "Migrating Claude Code from native to Homebrew..."
        rm -f "$HOME/.local/bin/claude"
        if [[ -f "$HOME/.claude.json" ]]; then
            jq '.installMethod = "brew"' "$HOME/.claude.json" > "$HOME/.claude.json.tmp" \
                && mv "$HOME/.claude.json.tmp" "$HOME/.claude.json"
        fi
        echo "Native Claude Code removed — now managed by Homebrew"
    fi

    if [[ -f ~/.zshrc ]]; then
        cp ~/.zshrc ~/.zshrc.bak
        echo "Backed up existing .zshrc to .zshrc.bak"
    fi

    brew_prefix="$(brew --prefix)"
    chmod -R go-w "$brew_prefix/share" "$brew_prefix/share/zsh" 2>/dev/null || true
    sed "s|BREW_PREFIX|$brew_prefix|g" "{{justfile_directory()}}/zshrc.template" > ~/.zshrc
    mkdir -p ~/.config
    cp "{{justfile_directory()}}/../starship.toml" ~/.config/starship.toml
    cp "{{justfile_directory()}}/../tmux.conf" ~/.tmux.conf

    echo "Setting up tmux plugin manager..."
    if [[ -d ~/.tmux/plugins/tpm ]]; then
        git -C ~/.tmux/plugins/tpm pull -q
    else
        git clone -q https://github.com/tmux-plugins/tpm ~/.tmux/plugins/tpm
    fi
    ~/.tmux/plugins/tpm/bin/install_plugins
    ~/.tmux/plugins/tpm/bin/update_plugins all

    echo "Cleaning up old Powerlevel10k artifacts..."
    rm -f ~/.p10k.zsh
    rm -f "${XDG_CACHE_HOME:-$HOME/.cache}"/p10k-instant-prompt-*.zsh
    brew uninstall powerlevel10k 2>/dev/null || true
    brew untap romkatv/powerlevel10k 2>/dev/null || true

    echo "Configuring Git..."
    git config --global user.name "Jakob Hviid, PhD"
    git config --global user.email "jakob@hviid.phd"
    git config --global pull.rebase true

    echo "✓ Zsh setup complete"
    echo "  Run 'exec zsh' to load changes"
