# Mac setup recipes — run from the Mac/ directory

# List available machines (Brewfile.* without the prefix)
_machines := `ls Brewfile.* 2>/dev/null | sed 's/Brewfile\.//' | tr '\n' ' '`

# List available profiles (*.mobileconfig without the extension)
_profiles := `ls *.mobileconfig 2>/dev/null | sed 's/\.mobileconfig//' | tr '\n' ' '`

# Show available commands
default:
    @echo "Mac setup — run from the Mac/ directory"
    @echo ""
    @echo "Commands:"
    @echo "  just install [machine]    Install Homebrew packages from a machine's Brewfile"
    @echo "  just backup [machine]     Dump current Homebrew state to a Brewfile (or create new)"
    @echo "  just cleanup [machine]    Uninstall packages not listed in a machine's Brewfile"
    @echo "  just profile [name]       Install a macOS configuration profile (.mobileconfig)"
    @echo "  just zsh                  Set up Zsh with plugins, Powerlevel10k, and config"
    @echo ""
    @echo "Available machines: {{_machines}}"
    @echo "Available profiles: {{_profiles}}"

# Install Homebrew packages from a machine's Brewfile
install machine="":
    #!/usr/bin/env zsh
    machine="{{machine}}"
    if [[ -z "$machine" ]]; then
        choices=( $(ls Brewfile.* 2>/dev/null | sed 's/Brewfile\.//') )
        echo "Available machines:"
        for i in {1..${#choices[@]}}; do echo "  $i) $choices[$i]"; done
        echo -n "Pick a machine (number or name): "
        read choice
        if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#choices[@]} )); then
            machine="$choices[$choice]"
        else
            machine="$choice"
        fi
    fi
    if [[ -z "$machine" ]]; then
        echo "No machine selected, exiting."
        exit 0
    fi
    if [[ ! -f "Brewfile.$machine" ]]; then
        echo "Error: Brewfile.$machine not found"
        exit 1
    fi
    echo "Installing from Brewfile.$machine..."
    brew bundle --file="Brewfile.$machine"

# Dump current Homebrew state to a Brewfile (or create a new one)
backup machine="":
    #!/usr/bin/env zsh
    machine="{{machine}}"
    if [[ -z "$machine" ]]; then
        choices=( $(ls Brewfile.* 2>/dev/null | sed 's/Brewfile\.//') )
        echo "Existing machines:"
        for i in {1..${#choices[@]}}; do echo "  $i) $choices[$i]"; done
        echo -n "Pick a machine (number, name, or new name): "
        read choice
        if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#choices[@]} )); then
            machine="$choices[$choice]"
        else
            machine="$choice"
        fi
    fi
    if [[ -z "$machine" ]]; then
        echo "No machine selected, exiting."
        exit 0
    fi
    if [[ -f "Brewfile.$machine" ]]; then
        echo "Overwriting Brewfile.$machine..."
    else
        echo "Creating new Brewfile.$machine..."
    fi
    brew bundle dump --file="Brewfile.$machine" --force
    echo "Done. Saved to Brewfile.$machine"

# Install a macOS configuration profile (.mobileconfig)
profile name="":
    #!/usr/bin/env zsh
    name="{{name}}"
    if [[ -z "$name" ]]; then
        choices=( $(ls *.mobileconfig 2>/dev/null | sed 's/\.mobileconfig//') )
        echo "Available profiles:"
        for i in {1..${#choices[@]}}; do echo "  $i) $choices[$i]"; done
        echo -n "Pick a profile (number or name): "
        read choice
        if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#choices[@]} )); then
            name="$choices[$choice]"
        else
            name="$choice"
        fi
    fi
    if [[ -z "$name" ]]; then
        echo "No profile selected, exiting."
        exit 0
    fi
    file="${name}.mobileconfig"
    if [[ ! -f "$file" ]]; then
        echo "Error: $file not found"
        exit 1
    fi
    echo "Installing profile $file..."
    open "$file"

# Uninstall packages not listed in a machine's Brewfile
cleanup machine="":
    #!/usr/bin/env zsh
    machine="{{machine}}"
    if [[ -z "$machine" ]]; then
        choices=( $(ls Brewfile.* 2>/dev/null | sed 's/Brewfile\.//') )
        echo "Available machines:"
        for i in {1..${#choices[@]}}; do echo "  $i) $choices[$i]"; done
        echo -n "Pick a machine (number or name): "
        read choice
        if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#choices[@]} )); then
            machine="$choices[$choice]"
        else
            machine="$choice"
        fi
    fi
    if [[ -z "$machine" ]]; then
        echo "No machine selected, exiting."
        exit 0
    fi
    if [[ ! -f "Brewfile.$machine" ]]; then
        echo "Error: Brewfile.$machine not found"
        exit 1
    fi
    output=$(brew bundle cleanup --file="Brewfile.$machine" 2>&1)
    if [[ -z "$output" ]]; then
        echo "Brewfile.$machine is in sync — nothing to clean up."
        exit 0
    fi
    section=""
    echo "Not in Brewfile.$machine:"
    echo "$output" | while IFS= read -r line; do
        if [[ "$line" == "Would uninstall casks:"* ]]; then
            section="casks"; echo ""; echo "  Casks:"
        elif [[ "$line" == "Would uninstall formulae:"* ]]; then
            section="formulae"; echo ""; echo "  Formulae:"
        elif [[ "$line" == "Would uninstall VSCode"* ]]; then
            section="vscode"; echo ""; echo "  VS Code extensions:"
        elif [[ "$line" == "Would \`brew cleanup\`:"* ]]; then
            section="cache"; echo ""; echo "  Cached files:"
        elif [[ "$line" == "Run \`brew"* || "$line" == "Run "* ]]; then
            continue
        elif [[ -n "$section" && -n "$line" ]]; then
            if [[ "$section" == "cache" ]]; then
                if [[ "$line" == "Would remove:"* ]]; then
                    echo "    ${line#Would remove: }"
                fi
            else
                for word in ${=line}; do
                    echo "    $word"
                done
            fi
        fi
    done
    echo ""
    echo "To uninstall these:"
    echo "  brew bundle cleanup --file=Brewfile.$machine --force"

# Set up Zsh with plugins, Powerlevel10k, and configuration
zsh:
    #!/usr/bin/env zsh
    echo "Installing Zsh plugins via Homebrew..."
    brew install \
        zsh-autosuggestions \
        zsh-syntax-highlighting \
        zsh-completions \
        zsh-history-substring-search \
        zsh-autopair \
        zsh-you-should-use \
        fzf \
        fzf-tab \
        zoxide \
        romkatv/powerlevel10k/powerlevel10k

    if [[ -f ~/.zshrc ]]; then
        cp ~/.zshrc ~/.zshrc.bak
        echo "Backed up existing .zshrc to .zshrc.bak"
    fi

    brew_prefix="$(brew --prefix)"

    cat > ~/.zshrc <<ZSHRC
# ─── Homebrew ─────────────────────────────────────────────────────────────────
if [[ -d /home/linuxbrew/.linuxbrew ]]; then
    eval "\$(/home/linuxbrew/.linuxbrew/bin/brew shellenv zsh)"
elif [[ -d /opt/homebrew ]]; then
    eval "\$(/opt/homebrew/bin/brew shellenv zsh)"
fi

# ─── Powerlevel10k instant prompt ─────────────────────────────────────────────
if [[ -r "\${XDG_CACHE_HOME:-\$HOME/.cache}/p10k-instant-prompt-\${(%):-%n}.zsh" ]]; then
    source "\${XDG_CACHE_HOME:-\$HOME/.cache}/p10k-instant-prompt-\${(%):-%n}.zsh"
fi

# ─── Prompt ───────────────────────────────────────────────────────────────────
source $brew_prefix/share/powerlevel10k/powerlevel10k.zsh-theme

# ─── Plugins ──────────────────────────────────────────────────────────────────
source $brew_prefix/share/zsh-autosuggestions/zsh-autosuggestions.zsh
source $brew_prefix/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
source $brew_prefix/share/zsh-history-substring-search/zsh-history-substring-search.zsh
source $brew_prefix/share/zsh-autopair/autopair.zsh
source $brew_prefix/share/zsh-you-should-use/you-should-use.plugin.zsh
source $brew_prefix/opt/fzf-tab/share/fzf-tab/fzf-tab.zsh

# ─── Completions ──────────────────────────────────────────────────────────────
FPATH=$brew_prefix/share/zsh-completions:\$FPATH
autoload -Uz compinit && compinit
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}'

# ─── History ──────────────────────────────────────────────────────────────────
HISTFILE=~/.zsh_history
HISTSIZE=10000
SAVEHIST=10000
setopt SHARE_HISTORY
setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_SPACE

# ─── Key bindings ─────────────────────────────────────────────────────────────
bindkey '^[[A' history-substring-search-up
bindkey '^[[B' history-substring-search-down

# ─── Zoxide (smart cd) ───────────────────────────────────────────────────────
eval "\$(zoxide init zsh)"

# ─── NVM (if installed) ──────────────────────────────────────────────────────
if [[ -d "\$HOME/.nvm" ]]; then
    export NVM_DIR="\$HOME/.nvm"
    [ -s "\$NVM_DIR/nvm.sh" ] && . "\$NVM_DIR/nvm.sh"
fi

# ─── Local npm bin ────────────────────────────────────────────────────────────
[[ -d "\$HOME/.local/npm/bin" ]] && export PATH="\$HOME/.local/npm/bin:\$PATH"

# ─── Powerlevel10k config ────────────────────────────────────────────────────
[[ -f ~/.p10k.zsh ]] && source ~/.p10k.zsh
ZSHRC

    cp "{{justfile_directory()}}/p10k.zsh" ~/.p10k.zsh

    echo "✓ Zsh setup complete — restart your terminal to activate"
    echo "  Run 'p10k configure' to customize the prompt theme"
