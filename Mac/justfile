# Mac setup recipes — run from the Mac/ directory

# List available machines (Brewfile.* without the prefix)
_machines := `ls brewfiles/Brewfile.* 2>/dev/null | xargs -n1 basename | sed 's/Brewfile\.//' | tr '\n' ' '`

# List available profiles (assets/*.mobileconfig without the extension/path)
_profiles := `ls assets/*.mobileconfig 2>/dev/null | xargs -n1 basename | sed 's/\.mobileconfig//' | tr '\n' ' '`

# Show available commands
default:
    @echo "Mac setup — run from the Mac/ directory"
    @echo ""
    @echo "Commands:"
    @echo "  just install [machine]    Install Homebrew packages from a machine's Brewfile"
    @echo "  just backup [machine]     Dump current Homebrew state to a Brewfile (or create new)"
    @echo "  just drift [machine]      Show what's out of sync with the repo (read-only)"
    @echo "  just brave                Apply Brave debloat profile + Cmd+W workaround"
    @echo "  just profile [name]       Install a macOS configuration profile (.mobileconfig)"
    @echo "  just zsh                  Set up Zsh with plugins, Starship prompt, and config"
    @echo ""
    @echo "Available machines: {{_machines}}"
    @echo "Available profiles: {{_profiles}}"

# Install Homebrew packages from a machine's Brewfile
install machine="":
    #!/usr/bin/env zsh
    source "{{justfile_directory()}}/lib/common.sh"
    machine="{{machine}}"
    if [[ -z "$machine" ]]; then
        choices=( $(ls brewfiles/Brewfile.* 2>/dev/null | xargs -n1 basename | sed 's/Brewfile\.//') )
        machine=$(pick_machine "Pick a machine (number or name): " "${choices[@]}")
    fi
    if [[ -z "$machine" ]]; then
        warn "No machine selected, exiting."
        exit 0
    fi
    if [[ ! -f "brewfiles/Brewfile.$machine" ]]; then
        err "brewfiles/Brewfile.$machine not found"
        exit 1
    fi
    info "Installing from brewfiles/Brewfile.$machine..."
    brew bundle --file="brewfiles/Brewfile.$machine"

    just zsh
    just brave

# Dump current Homebrew state to a Brewfile (or create a new one)
backup machine="":
    #!/usr/bin/env zsh
    source "{{justfile_directory()}}/lib/common.sh"
    machine="{{machine}}"
    if [[ -z "$machine" ]]; then
        choices=( $(ls brewfiles/Brewfile.* 2>/dev/null | xargs -n1 basename | sed 's/Brewfile\.//') )
        machine=$(pick_machine "Pick a machine (number, name, or new name): " "${choices[@]}")
    fi
    if [[ -z "$machine" ]]; then
        warn "No machine selected, exiting."
        exit 0
    fi
    mkdir -p brewfiles
    if [[ -f "brewfiles/Brewfile.$machine" ]]; then
        info "Overwriting brewfiles/Brewfile.$machine..."
    else
        info "Creating new brewfiles/Brewfile.$machine..."
    fi
    brew bundle dump --file="brewfiles/Brewfile.$machine" --force --no-vscode
    ok "Saved to brewfiles/Brewfile.$machine"

# Apply the Brave debloat profile + Cmd+W keyboard workaround. Thin wrapper — calls 'just profile brave-debloat' which carries the keybinding fix as a pre-install step.
brave:
    just profile brave-debloat

# Install a macOS configuration profile (assets/<name>.mobileconfig). Some profiles carry pre-install companion steps (e.g. brave-debloat applies a Cmd+W keybinding fix).
profile name="":
    #!/usr/bin/env zsh
    source "{{justfile_directory()}}/lib/common.sh"
    name="{{name}}"
    if [[ -z "$name" ]]; then
        choices=( $(ls assets/*.mobileconfig 2>/dev/null | xargs -n1 basename | sed 's/\.mobileconfig//') )
        name=$(pick_choice "Pick a profile (number or name): " "" "${choices[@]}")
    fi
    if [[ -z "$name" ]]; then
        warn "No profile selected, exiting."
        exit 0
    fi
    file="assets/${name}.mobileconfig"
    if [[ ! -f "$file" ]]; then
        err "$file not found"
        exit 1
    fi

    # Pre-install companion steps run BEFORE 'open' — System Settings →
    # Profiles is user-blocking, so anything we want done without waiting
    # on a click-through has to happen here.
    case "$name" in
        brave-debloat)
            # Workaround for an intermittent Chromium bug where Brave's File
            # menu loses the 'Close Tab' item and 'Close Window' steals ⌘W.
            # -dict-add merges into NSUserKeyEquivalents instead of clobbering
            # any other App Shortcuts you've configured. Restart Brave for it
            # to take effect.
            info "Rebinding Brave's 'Close Window' to ⌘⇧W..."
            defaults write com.brave.Browser NSUserKeyEquivalents -dict-add "Close Window" '@$w'
            ;;
    esac

    info "Installing profile $file..."
    open "$file"

# Show what's out of sync with the repo. Read-only — points at recipes to converge.
drift machine="":
    #!/usr/bin/env zsh
    source "{{justfile_directory()}}/lib/common.sh"
    machine="{{machine}}"
    if [[ -z "$machine" ]]; then
        choices=( $(ls brewfiles/Brewfile.* 2>/dev/null | xargs -n1 basename | sed 's/Brewfile\.//') )
        machine=$(pick_machine "Pick a machine (number or name): " "${choices[@]}")
    fi
    if [[ -z "$machine" ]]; then
        warn "No machine selected, exiting."
        exit 0
    fi
    if [[ ! -f "brewfiles/Brewfile.$machine" ]]; then
        err "brewfiles/Brewfile.$machine not found"
        exit 1
    fi

    typeset -a fixes
    brew_prefix="$(brew --prefix)"
    here="{{justfile_directory()}}"

    # ── zsh templates ──────────────────────────────────────────────────
    echo
    echo "zsh"
    rendered=$(mktemp)
    sed "s|BREW_PREFIX|$brew_prefix|g" "$here/assets/zshrc.template" > "$rendered"
    zd=0
    for pair in \
        "$rendered:$HOME/.zshrc" \
        "$here/../shared/starship.toml:$HOME/.config/starship.toml" \
        "$here/../shared/tmux.conf:$HOME/.tmux.conf"
    do
        src="${pair%%:*}"; dst="${pair#*:}"; label="${dst/#$HOME/~}"
        if [[ ! -f "$dst" ]]; then
            printf '  %-30s ✗ missing\n' "$label"; zd=1
        elif diff -q "$src" "$dst" >/dev/null 2>&1; then
            printf '  %-30s ✓\n' "$label"
        else
            n=$(diff "$src" "$dst" 2>/dev/null | grep -c '^[<>]')
            printf '  %-30s ✗ %d lines differ\n' "$label" "$n"; zd=1
        fi
    done
    rm -f "$rendered"
    (( zd )) && fixes+=("zsh             → just zsh")

    # ── default shell ──────────────────────────────────────────────────
    echo
    echo "default shell"
    if [[ "$(basename "$SHELL")" == "zsh" ]]; then
        printf '  ✓ %s\n' "$SHELL"
    else
        printf '  ✗ %s (expected zsh)\n' "$SHELL"
        fixes+=("default shell   → chsh -s \$(which zsh)")
    fi

    # ── git identity ───────────────────────────────────────────────────
    echo
    echo "git identity"
    typeset -A git_expected
    git_expected[user.name]="Jakob Hviid, PhD"
    git_expected[user.email]="jakob@hviid.phd"
    git_expected[pull.rebase]="true"
    gd=0
    for k in user.name user.email pull.rebase; do
        actual=$(git config --global "$k" 2>/dev/null)
        if [[ "$actual" == "${git_expected[$k]}" ]]; then
            printf '  %-30s ✓\n' "$k"
        else
            printf '  %-30s ✗ %s (expected %s)\n' "$k" "${actual:-<unset>}" "${git_expected[$k]}"
            gd=1
        fi
    done
    (( gd )) && fixes+=("git identity    → just zsh")

    # ── brave (mobileconfig vs Managed Preferences) ────────────────────
    echo
    echo "brave (mobileconfig)"
    managed="/Library/Managed Preferences/$(whoami)/com.brave.Browser.plist"
    profile_src="$here/assets/brave-debloat.mobileconfig"
    bd=0
    if [[ ! -f "$managed" ]]; then
        printf '  ✗ profile not installed (no %s)\n' "$managed"
        bd=1
    else
        expected_json=$(plutil -convert json -o - "$profile_src" 2>/dev/null \
            | jq '.PayloadContent[0] | with_entries(select(.key|startswith("Payload")|not))')
        actual_json=$(plutil -convert json -o - "$managed" 2>/dev/null || echo '{}')
        mismatches=$(jq -r --argjson actual "$actual_json" '
            to_entries[] |
            select((.value | tojson) != ($actual[.key] | tojson)) |
            "\(.key)\t\(.value | tojson)\t\(($actual[.key] // null) | tojson)"
        ' <<< "$expected_json")
        if [[ -z "$mismatches" ]]; then
            printf '  ✓ all keys match\n'
        else
            while IFS=$'\t' read -r key exp act; do
                printf '  %-40s ✗ expected=%s actual=%s\n' "$key" "$exp" "$act"
            done <<< "$mismatches"
            bd=1
        fi
    fi
    (( bd )) && fixes+=("brave           → just brave")

    # ── brewfile ───────────────────────────────────────────────────────
    echo
    echo "brewfile (Brewfile.$machine)"
    bf="brewfiles/Brewfile.$machine"
    bfd=0

    # Missing entries — direct brew/mas/code checks; brew bundle check is
    # unreliable for auto-updating casks (Discord, VS Code etc.) where the
    # manifest drifts from disk.
    casks_installed=$(brew list --cask 2>/dev/null)
    formulae_installed=$(brew list --formula 2>/dev/null)
    taps_installed=$(brew tap 2>/dev/null)
    mas_installed=""
    command -v mas &>/dev/null && mas_installed=$(mas list 2>/dev/null | awk '{print $1}')
    vscode_installed=""
    command -v code &>/dev/null && vscode_installed=$(code --list-extensions 2>/dev/null)

    typeset -a missing_bf
    while IFS= read -r line; do
        case "$line" in
            'brew '*)
                name=$(echo "$line" | sed -E 's/^brew "([^"]+)".*/\1/')
                echo "$formulae_installed" | grep -qFx "$name" || missing_bf+=("brew $name")
                ;;
            'cask '*)
                name=$(echo "$line" | sed -E 's/^cask "([^"]+)".*/\1/')
                echo "$casks_installed" | grep -qFx "$name" || missing_bf+=("cask $name")
                ;;
            'tap '*)
                name=$(echo "$line" | sed -E 's/^tap "([^"]+)".*/\1/')
                echo "$taps_installed" | grep -qFx "$name" || missing_bf+=("tap $name")
                ;;
            'mas '*)
                id=$(echo "$line" | sed -E 's/.*id: ([0-9]+).*/\1/')
                name=$(echo "$line" | sed -E 's/^mas "([^"]+)".*/\1/')
                if [[ -n "$mas_installed" ]]; then
                    echo "$mas_installed" | grep -qFx "$id" || missing_bf+=("mas $name ($id)")
                fi
                ;;
            'vscode '*)
                ext=$(echo "$line" | sed -E 's/^vscode "([^"]+)".*/\1/')
                if [[ -n "$vscode_installed" ]]; then
                    echo "$vscode_installed" | grep -qFix "$ext" || missing_bf+=("vscode $ext")
                fi
                ;;
        esac
    done < <(grep -vE '^\s*#|^\s*$' "$bf")

    if (( ${#missing_bf[@]} == 0 )); then
        printf '  ✓ all Brewfile entries installed\n'
    else
        printf '  ✗ %d Brewfile entries not installed on this machine:\n' "${#missing_bf[@]}"
        printf '      %s\n' "${missing_bf[@]}"
        bfd=1
    fi

    # Extras
    cleanup_out=$(brew bundle cleanup --file="$bf" --formula --cask --tap 2>&1 || true)
    extras=$(echo "$cleanup_out" | sed -n '/^Would uninstall/,/^[A-Z]/p' | grep -E '^[a-z0-9][a-z0-9._/-]*$' || true)
    if [[ -z "$extras" ]]; then
        printf '  ✓ no extras (everything installed is in the Brewfile)\n'
    else
        n=$(echo "$extras" | wc -l | tr -d ' ')
        printf '  ✗ %s packages installed but not in the Brewfile:\n' "$n"
        echo "$extras" | sed 's/^/      /'
        bfd=1
    fi
    (( bfd )) && {
        fixes+=("brewfile        → brew bundle install --file=$bf   (missing)")
        fixes+=("                → brew bundle cleanup --file=$bf --formula --cask --tap --force   (extras)")
    }

    # ── Summary ────────────────────────────────────────────────────────
    echo
    echo "Summary"
    if (( ${#fixes[@]} == 0 )); then
        ok "Everything in sync."
    else
        printf '  %s\n' "${fixes[@]}"
    fi

# Set up Zsh with plugins, Starship prompt, and configuration
zsh:
    #!/usr/bin/env zsh
    echo "Installing Zsh plugins and CLI tools via Homebrew..."
    brew tap joshmedeski/sesh 2>/dev/null || true
    brew install \
        zsh-autosuggestions \
        zsh-syntax-highlighting \
        zsh-completions \
        zsh-history-substring-search \
        zsh-autopair \
        zsh-you-should-use \
        bat \
        eza \
        fzf \
        fzf-tab \
        zoxide \
        starship \
        tmux \
        lazygit \
        sesh \
        claude-code \
        jq

    # Migrate native Claude Code install to Homebrew
    if [[ -f "$HOME/.local/bin/claude" ]]; then
        echo "Migrating Claude Code from native to Homebrew..."
        rm -f "$HOME/.local/bin/claude"
        if [[ -f "$HOME/.claude.json" ]]; then
            jq '.installMethod = "brew"' "$HOME/.claude.json" > "$HOME/.claude.json.tmp" \
                && mv "$HOME/.claude.json.tmp" "$HOME/.claude.json"
        fi
        echo "Native Claude Code removed — now managed by Homebrew"
    fi

    if [[ -f ~/.zshrc ]]; then
        cp ~/.zshrc ~/.zshrc.bak
        echo "Backed up existing .zshrc to .zshrc.bak"
    fi

    brew_prefix="$(brew --prefix)"
    chmod -R go-w "$brew_prefix/share" "$brew_prefix/share/zsh" 2>/dev/null || true
    sed "s|BREW_PREFIX|$brew_prefix|g" "{{justfile_directory()}}/assets/zshrc.template" > ~/.zshrc
    mkdir -p ~/.config
    cp "{{justfile_directory()}}/../shared/starship.toml" ~/.config/starship.toml
    cp "{{justfile_directory()}}/../shared/tmux.conf" ~/.tmux.conf

    echo "Setting up tmux plugin manager..."
    if [[ -d ~/.tmux/plugins/tpm ]]; then
        git -C ~/.tmux/plugins/tpm pull -q
    else
        git clone -q https://github.com/tmux-plugins/tpm ~/.tmux/plugins/tpm
    fi
    ~/.tmux/plugins/tpm/bin/install_plugins
    ~/.tmux/plugins/tpm/bin/update_plugins all

    echo "Cleaning up old Powerlevel10k artifacts..."
    rm -f ~/.p10k.zsh
    rm -f "${XDG_CACHE_HOME:-$HOME/.cache}"/p10k-instant-prompt-*.zsh
    brew uninstall powerlevel10k 2>/dev/null || true
    brew untap romkatv/powerlevel10k 2>/dev/null || true

    echo "Configuring Git..."
    git config --global user.name "Jakob Hviid, PhD"
    git config --global user.email "jakob@hviid.phd"
    git config --global pull.rebase true

    echo "✓ Zsh setup complete"
    echo "  Run 'exec zsh' to load changes"
